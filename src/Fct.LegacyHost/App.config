<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <!-- Matches real ACT: gates WinForms into the 4.7+ high-DPI quirking level so
         EnableWindowsFormsHighDpiAutoResizing takes effect. -->
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7" />
  </startup>
  <!-- AutoGenerateBindingRedirects merges the generated <assemblyBinding> redirects into this
       <runtime> element (Serilog's net48 dependencies need them in the plugin-hosting process). -->
  <runtime>
  </runtime>
  <System.Windows.Forms.ApplicationConfigurationSection>
    <!-- WinForms auto-scales controls from their design (96 DPI) size to the system DPI. This is
         the mechanism ACT relies on; ActGlobals.oFormActMain.DpiScale is derived from it. -->
    <add key="EnableWindowsFormsHighDpiAutoResizing" value="true" />
  </System.Windows.Forms.ApplicationConfigurationSection>
</configuration>
