<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:Fct.App.Converters"
             x:Class="Fct.App.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <!-- Evercold palette: a frozen near-black field with a single warm flare. -->
            <Color x:Key="AbyssColor">#0A0D12</Color>
            <Color x:Key="GlacierColor">#121822</Color>
            <Color x:Key="RimeColor">#1B2430</Color>
            <Color x:Key="RimeHiColor">#22303F</Color>
            <Color x:Key="FrostColor">#8FD4F0</Color>
            <Color x:Key="FrostDimColor">#5E93AE</Color>
            <Color x:Key="GlintColor">#D8E8F2</Color>
            <Color x:Key="HoarfrostColor">#6E8197</Color>
            <Color x:Key="EmberColor">#E8A24C</Color>
            <Color x:Key="WarnColor">#D9695A</Color>
            <Color x:Key="HairlineColor">#22303C</Color>

            <SolidColorBrush x:Key="AbyssBrush" Color="{StaticResource AbyssColor}"/>
            <SolidColorBrush x:Key="GlacierBrush" Color="{StaticResource GlacierColor}"/>
            <SolidColorBrush x:Key="RimeBrush" Color="{StaticResource RimeColor}"/>
            <SolidColorBrush x:Key="RimeHiBrush" Color="{StaticResource RimeHiColor}"/>
            <SolidColorBrush x:Key="FrostBrush" Color="{StaticResource FrostColor}"/>
            <SolidColorBrush x:Key="FrostDimBrush" Color="{StaticResource FrostDimColor}"/>
            <SolidColorBrush x:Key="GlintBrush" Color="{StaticResource GlintColor}"/>
            <SolidColorBrush x:Key="HoarfrostBrush" Color="{StaticResource HoarfrostColor}"/>
            <SolidColorBrush x:Key="EmberBrush" Color="{StaticResource EmberColor}"/>
            <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource WarnColor}"/>
            <SolidColorBrush x:Key="HairlineBrush" Color="{StaticResource HairlineColor}"/>

            <!-- Frost rule: cyan fading to nothing, the wordmark underline. -->
            <LinearGradientBrush x:Key="FrostRuleBrush" StartPoint="0%,0%" EndPoint="100%,0%">
                <GradientStop Color="#8FD4F0" Offset="0"/>
                <GradientStop Color="#2A8FD4F0" Offset="0.55"/>
                <GradientStop Color="#008FD4F0" Offset="1"/>
            </LinearGradientBrush>

            <!-- Window atmosphere: a cold vertical wash, lighter at the crown. -->
            <LinearGradientBrush x:Key="AtmosphereBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#141E2A" Offset="0"/>
                <GradientStop Color="#0A0D12" Offset="0.45"/>
                <GradientStop Color="#070A0E" Offset="1"/>
            </LinearGradientBrush>

            <FontFamily x:Key="DisplayFont">Bahnschrift SemiBold, Bahnschrift, Segoe UI Semibold, Inter, sans-serif</FontFamily>
            <FontFamily x:Key="BodyFont">avares://Avalonia.Fonts.Inter/Assets#Inter</FontFamily>
            <FontFamily x:Key="MonoFont">Cascadia Mono, Cascadia Code, Consolas, monospace</FontFamily>

            <!-- ============================================================================
                 Plugin design-token contract (Fct.Abstractions.UI FctTokens; docs/UI-TOKENS.md).
                 The stable, semantic seam plugins bind via {DynamicResource}. Maps onto the
                 Evercold palette above; the shell may re-map these (light variant, re-accent)
                 without touching the plugin contract. Keep in sync with FctTokens/FctStyleClasses. -->
            <SolidColorBrush x:Key="FctBackground" Color="{StaticResource AbyssColor}"/>
            <SolidColorBrush x:Key="FctSurface" Color="{StaticResource GlacierColor}"/>
            <SolidColorBrush x:Key="FctSurfaceAlt" Color="{StaticResource RimeColor}"/>
            <SolidColorBrush x:Key="FctSurfaceHi" Color="{StaticResource RimeHiColor}"/>
            <SolidColorBrush x:Key="FctAccent" Color="{StaticResource FrostColor}"/>
            <SolidColorBrush x:Key="FctAccentDim" Color="{StaticResource FrostDimColor}"/>
            <SolidColorBrush x:Key="FctText" Color="{StaticResource GlintColor}"/>
            <SolidColorBrush x:Key="FctTextDim" Color="{StaticResource HoarfrostColor}"/>
            <SolidColorBrush x:Key="FctEmphasis" Color="{StaticResource EmberColor}"/>
            <SolidColorBrush x:Key="FctDanger" Color="{StaticResource WarnColor}"/>
            <SolidColorBrush x:Key="FctHairline" Color="{StaticResource HairlineColor}"/>

            <FontFamily x:Key="FctFontDisplay">Bahnschrift SemiBold, Bahnschrift, Segoe UI Semibold, Inter, sans-serif</FontFamily>
            <FontFamily x:Key="FctFontBody">avares://Avalonia.Fonts.Inter/Assets#Inter</FontFamily>
            <FontFamily x:Key="FctFontMono">Cascadia Mono, Cascadia Code, Consolas, monospace</FontFamily>

            <!-- Tint the Fluent ToggleSwitch "on" state frost. -->
            <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="{StaticResource FrostColor}"/>
            <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="{StaticResource FrostColor}"/>
            <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="{StaticResource FrostDimColor}"/>
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="{StaticResource AbyssColor}"/>
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver" Color="{StaticResource AbyssColor}"/>
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPressed" Color="{StaticResource AbyssColor}"/>

            <conv:StatusToBrushConverter x:Key="StatusToBrush"/>
            <conv:SeverityToBrushConverter x:Key="SeverityToBrush"/>
            <conv:EnumEqualsConverter x:Key="EnumEquals"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Fct.App/Styles/Controls.axaml"/>
        <!-- Blessed plugin-facing style classes (fct-*), applied after the shell's own. -->
        <StyleInclude Source="avares://Fct.App/Styles/PluginTokens.axaml"/>
    </Application.Styles>
</Application>
