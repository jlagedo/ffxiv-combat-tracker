<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================ Typography ============================ -->
    <Style Selector="TextBlock.eyebrow">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="LetterSpacing" Value="2.5"/>
        <Setter Property="Foreground" Value="{StaticResource HoarfrostBrush}"/>
    </Style>
    <Style Selector="TextBlock.h1">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize" Value="30"/>
        <Setter Property="LetterSpacing" Value="0.5"/>
        <Setter Property="Foreground" Value="{StaticResource GlintBrush}"/>
    </Style>
    <Style Selector="TextBlock.h2">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize" Value="19"/>
        <Setter Property="Foreground" Value="{StaticResource GlintBrush}"/>
    </Style>
    <Style Selector="TextBlock.subtitle">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource HoarfrostBrush}"/>
        <Setter Property="LineHeight" Value="19"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style Selector="TextBlock.meta">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource HoarfrostBrush}"/>
    </Style>
    <Style Selector="TextBlock.body">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource GlintBrush}"/>
        <Setter Property="LineHeight" Value="20"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ============================ Motion vocabulary ============================
         One consistent language across the shell:
           · entrance   — .rise1..6, a staggered fade + 16px lift (FillMode None so
                          hover/press transforms still own RenderTransform afterwards)
           · hover-lift — interactive surfaces float 4px and bloom frost
           · press      — tactile scale to 0.97
           · ambient    — slow, low-amplitude loops (orb pulse, crown breath, live ping)
         Easing is CubicEaseOut for intent-driven motion, SineEaseInOut for ambient. -->
    <!-- Each rise class carries its own complete animation (Avalonia runs the animations
         from every matching style, so a shared base + delay-only override would double up
         and cancel the stagger). Delay climbs 60ms per step to cascade a group in. -->
    <Style Selector=":is(Control).rise1">
        <Style.Animations>
            <Animation Duration="0:0:0.46" Delay="0:0:0" Easing="CubicEaseOut" FillMode="None">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/><Setter Property="TranslateTransform.Y" Value="16"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/><Setter Property="TranslateTransform.Y" Value="0"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector=":is(Control).rise2">
        <Style.Animations>
            <Animation Duration="0:0:0.46" Delay="0:0:0.06" Easing="CubicEaseOut" FillMode="None">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/><Setter Property="TranslateTransform.Y" Value="16"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/><Setter Property="TranslateTransform.Y" Value="0"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector=":is(Control).rise3">
        <Style.Animations>
            <Animation Duration="0:0:0.46" Delay="0:0:0.12" Easing="CubicEaseOut" FillMode="None">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/><Setter Property="TranslateTransform.Y" Value="16"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/><Setter Property="TranslateTransform.Y" Value="0"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector=":is(Control).rise4">
        <Style.Animations>
            <Animation Duration="0:0:0.46" Delay="0:0:0.18" Easing="CubicEaseOut" FillMode="None">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/><Setter Property="TranslateTransform.Y" Value="16"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/><Setter Property="TranslateTransform.Y" Value="0"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector=":is(Control).rise5">
        <Style.Animations>
            <Animation Duration="0:0:0.46" Delay="0:0:0.24" Easing="CubicEaseOut" FillMode="None">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/><Setter Property="TranslateTransform.Y" Value="16"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/><Setter Property="TranslateTransform.Y" Value="0"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector=":is(Control).rise6">
        <Style.Animations>
            <Animation Duration="0:0:0.46" Delay="0:0:0.30" Easing="CubicEaseOut" FillMode="None">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/><Setter Property="TranslateTransform.Y" Value="16"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/><Setter Property="TranslateTransform.Y" Value="0"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================ Surfaces ============================ -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource GlacierBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>
    <Style Selector="Border.rule">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{StaticResource FrostRuleBrush}"/>
    </Style>

    <!-- Stat tile: a small, glanceable card that lifts and blooms frost on hover. -->
    <Style Selector="Border.stat">
        <Setter Property="RenderTransform" Value="translateY(0px)"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #0014A0E0"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.19" Easing="CubicEaseOut"/>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.19"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.19"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.stat:pointerover">
        <Setter Property="RenderTransform" Value="translateY(-4px)"/>
        <Setter Property="BoxShadow" Value="0 12 30 -8 #4014A0E0"/>
        <Setter Property="BorderBrush" Value="{StaticResource FrostDimBrush}"/>
    </Style>

    <!-- ============================ Nav rail ============================ -->
    <Style Selector="Button.nav">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="RenderTransform" Value="scale(1)"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.11" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.nav:pressed">
        <Setter Property="RenderTransform" Value="scale(0.97)"/>
    </Style>
    <Style Selector="Button.nav /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="RenderTransform" Value="translateX(0px)"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource RimeBrush}"/>
        <Setter Property="RenderTransform" Value="translateX(3px)"/>
    </Style>
    <Style Selector="Button.nav.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource RimeBrush}"/>
    </Style>
    <Style Selector="Button.nav TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HoarfrostBrush}"/>
    </Style>
    <Style Selector="Button.nav Path">
        <Setter Property="Fill" Value="{StaticResource HoarfrostBrush}"/>
    </Style>
    <Style Selector="Button.nav:pointerover TextBlock">
        <Setter Property="Foreground" Value="{StaticResource GlintBrush}"/>
    </Style>
    <Style Selector="Button.nav:pointerover Path">
        <Setter Property="Fill" Value="{StaticResource FrostBrush}"/>
    </Style>
    <Style Selector="Button.nav.active TextBlock">
        <Setter Property="Foreground" Value="{StaticResource GlintBrush}"/>
    </Style>
    <Style Selector="Button.nav.active Path">
        <Setter Property="Fill" Value="{StaticResource FrostBrush}"/>
    </Style>
    <Style Selector="Button.nav:focus-visible /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="{StaticResource FrostBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Active marker: grows in from the centre and holds. -->
    <Style Selector="Button.nav Rectangle.navbar">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransform" Value="scaleY(0.25)"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.24" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.nav.active Rectangle.navbar">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="RenderTransform" Value="scaleY(1)"/>
    </Style>

    <!-- ============================ Window chrome ============================ -->
    <Style Selector="Button.win">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.win /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Transitions">
            <Transitions><BrushTransition Property="Background" Duration="0:0:0.13"/></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.win Path">
        <Setter Property="Stroke" Value="{StaticResource HoarfrostBrush}"/>
        <Setter Property="Transitions">
            <Transitions><BrushTransition Property="Stroke" Duration="0:0:0.13"/></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.win:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource RimeBrush}"/>
    </Style>
    <Style Selector="Button.win:pointerover Path">
        <Setter Property="Stroke" Value="{StaticResource GlintBrush}"/>
    </Style>
    <Style Selector="Button.win.close:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource WarnBrush}"/>
    </Style>
    <Style Selector="Button.win.close:pointerover Path">
        <Setter Property="Stroke" Value="#0A0D12"/>
    </Style>

    <!-- ============================ Plugin roster ============================ -->
    <Style Selector="ListBox.roster">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ListBox.roster ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>
    <Style Selector="ListBox.roster ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.roster ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.roster ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Border.pcard">
        <Setter Property="Background" Value="{StaticResource GlacierBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="ListBox.roster ListBoxItem:pointerover Border.pcard">
        <Setter Property="Background" Value="{StaticResource RimeBrush}"/>
    </Style>
    <Style Selector="ListBox.roster ListBoxItem:selected Border.pcard">
        <Setter Property="Background" Value="{StaticResource RimeBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FrostDimBrush}"/>
    </Style>
    <Style Selector="ListBox.roster ListBoxItem:selected Rectangle.selbar">
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Rectangle.selbar">
        <Setter Property="Opacity" Value="0"/>
    </Style>

    <!-- ============================ Buttons ============================ -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource FrostDimBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource FrostBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,9"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="RenderTransform" Value="translateY(0px)"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.16" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.ghost /template/ ContentPresenter">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.16"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.16"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.ghost:pointerover">
        <Setter Property="RenderTransform" Value="translateY(-2px)"/>
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource RimeBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FrostBrush}"/>
    </Style>
    <Style Selector="Button.ghost:pressed">
        <Setter Property="RenderTransform" Value="scale(0.97)"/>
    </Style>
    <Style Selector="Button.ghost:focus-visible /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="{StaticResource FrostBrush}"/>
    </Style>

    <!-- ============================ Channel rail ============================ -->
    <Style Selector="ListBox.rail">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ListBox.rail ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>
    <Style Selector="ListBox.rail ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.rail ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.rail ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Border.railcard">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10,9"/>
        <Setter Property="RenderTransform" Value="translateX(0px)"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="ListBox.rail ListBoxItem:pointerover Border.railcard">
        <Setter Property="Background" Value="{StaticResource RimeBrush}"/>
        <Setter Property="RenderTransform" Value="translateX(3px)"/>
    </Style>
    <Style Selector="ListBox.rail ListBoxItem:selected Border.railcard">
        <Setter Property="Background" Value="{StaticResource RimeHiBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FrostDimBrush}"/>
    </Style>
    <Style Selector="Rectangle.railbar">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransform" Value="scaleY(0.25)"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.24" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="ListBox.rail ListBoxItem:selected Rectangle.railbar">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="RenderTransform" Value="scaleY(1)"/>
    </Style>

    <!-- Manage button at the foot of the rail -->
    <Style Selector="Button.railmanage">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="RenderTransform" Value="scale(1)"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.11" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.railmanage:pressed">
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>
    <Style Selector="Button.railmanage /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Transitions">
            <Transitions><BrushTransition Property="Background" Duration="0:0:0.15"/></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.railmanage TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HoarfrostBrush}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="Button.railmanage Path">
        <Setter Property="Stroke" Value="{StaticResource HoarfrostBrush}"/>
    </Style>
    <Style Selector="Button.railmanage:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource RimeBrush}"/>
    </Style>
    <Style Selector="Button.railmanage:pointerover TextBlock">
        <Setter Property="Foreground" Value="{StaticResource GlintBrush}"/>
    </Style>
    <Style Selector="Button.railmanage:pointerover Path">
        <Setter Property="Stroke" Value="{StaticResource FrostBrush}"/>
    </Style>
    <Style Selector="Button.railmanage.active">
        <Setter Property="BorderBrush" Value="{StaticResource FrostDimBrush}"/>
    </Style>
    <Style Selector="Button.railmanage.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource RimeHiBrush}"/>
    </Style>
    <Style Selector="Button.railmanage.active TextBlock">
        <Setter Property="Foreground" Value="{StaticResource GlintBrush}"/>
    </Style>
    <Style Selector="Button.railmanage.active Path">
        <Setter Property="Stroke" Value="{StaticResource FrostBrush}"/>
    </Style>

    <!-- ============================ Manage rack ============================ -->
    <Style Selector="Border.rackrow">
        <Setter Property="Background" Value="#0E1620"/>
        <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #00119ADB"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.rackrow:pointerover">
        <Setter Property="Background" Value="{StaticResource RimeBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FrostDimBrush}"/>
        <Setter Property="BoxShadow" Value="0 6 18 -6 #33119ADB"/>
    </Style>

    <!-- Small icon buttons (reorder / remove) -->
    <Style Selector="Button.iconbtn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="26"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="RenderTransform" Value="scale(1)"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.iconbtn:pressed">
        <Setter Property="RenderTransform" Value="scale(0.88)"/>
    </Style>
    <Style Selector="Button.iconbtn /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Transitions">
            <Transitions><BrushTransition Property="Background" Duration="0:0:0.13"/></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.iconbtn Path">
        <Setter Property="Stroke" Value="{StaticResource HoarfrostBrush}"/>
        <Setter Property="Transitions">
            <Transitions><BrushTransition Property="Stroke" Duration="0:0:0.13"/></Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.iconbtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource RimeHiBrush}"/>
    </Style>
    <Style Selector="Button.iconbtn:pointerover Path">
        <Setter Property="Stroke" Value="{StaticResource GlintBrush}"/>
    </Style>
    <Style Selector="Button.iconbtn.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#3A1B1E"/>
    </Style>
    <Style Selector="Button.iconbtn.danger:pointerover Path">
        <Setter Property="Stroke" Value="{StaticResource WarnBrush}"/>
    </Style>

    <!-- ============================ Status orb pulse ============================ -->
    <Style Selector=":is(Control).pulse">
        <Style.Animations>
            <Animation Duration="0:0:2.6" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.95"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Live radar: a frost ring that expands and fades from the data-source orb.
         Present only while the plugin binds IsLive; hidden (Opacity 0) otherwise. -->
    <Style Selector="Ellipse.ping">
        <Setter Property="Opacity" Value="0"/>
        <Style.Animations>
            <Animation Duration="0:0:1.9" IterationCount="INFINITE" Easing="CubicEaseOut">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.55"/><Setter Property="ScaleTransform.ScaleX" Value="0.55"/><Setter Property="ScaleTransform.ScaleY" Value="0.55"/></KeyFrame>
                <KeyFrame Cue="75%"><Setter Property="Opacity" Value="0"/><Setter Property="ScaleTransform.ScaleX" Value="2.4"/><Setter Property="ScaleTransform.ScaleY" Value="2.4"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0"/><Setter Property="ScaleTransform.ScaleX" Value="2.4"/><Setter Property="ScaleTransform.ScaleY" Value="2.4"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Ambient crown: the crystal-needle fan breathes, barely. -->
    <Style Selector="Path.crownfan">
        <Style.Animations>
            <Animation Duration="0:0:7" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.04"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.1"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================ ToggleSwitch (frost) ============================ -->
    <Style Selector="ToggleSwitch">
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource GlintBrush}"/>
    </Style>

</Styles>
