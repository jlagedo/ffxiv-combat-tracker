<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Fct.App.ViewModels"
        xmlns:views="using:Fct.App.Views"
        xmlns:lang="using:Fct.App.Lang"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="Fct.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="FFXIV Combat Tracker"
        Width="1180" Height="760" MinWidth="980" MinHeight="640"
        FontFamily="{StaticResource BodyFont}"
        Background="{StaticResource AbyssBrush}"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True">

    <!-- Each content page maps to its view; the shell swaps CurrentPage. -->
    <Window.DataTemplates>
        <DataTemplate DataType="vm:OverviewViewModel"><views:OverviewView/></DataTemplate>
        <DataTemplate DataType="vm:PluginsViewModel"><views:PluginsView/></DataTemplate>
        <DataTemplate DataType="vm:EncountersViewModel"><views:EncountersView/></DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel"><views:SettingsView/></DataTemplate>
    </Window.DataTemplates>

    <Grid>
        <!-- Frozen atmosphere: cold vertical wash + a faint crystal-needle fan at the crown -->
        <Rectangle Fill="{StaticResource AtmosphereBrush}"/>
        <Path Classes="crownfan" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-30,0,0"
              Width="600" Stretch="Uniform" Opacity="0.06" Fill="{StaticResource FrostBrush}"
              Data="M260 0 L268 220 L276 0 Z M222 26 L264 210 L238 24 Z M298 26 L266 210 L282 24 Z M186 64 L260 200 L208 60 Z M334 64 L270 200 L312 60 Z M150 104 L256 188 L182 100 Z M370 104 L274 188 L338 100 Z"/>

        <DockPanel>
            <!-- ============================ Title bar ============================ -->
            <Border DockPanel.Dock="Top" Height="46" Background="Transparent"
                    Name="TitleBar" WindowDecorationProperties.ElementRole="TitleBar">
                <Grid Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="11">
                        <Path Width="16" Height="16" Stretch="Uniform" Fill="{StaticResource FrostBrush}"
                              Data="M11 1 L20 9 L11 22 L2 9 Z"/>
                        <TextBlock Text="FFXIV" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                   LetterSpacing="3" Foreground="{StaticResource FrostBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Width="1" Height="14" Background="{StaticResource HairlineBrush}"/>
                        <TextBlock Text="COMBAT TRACKER" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="14" LetterSpacing="2" Foreground="{StaticResource GlintBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Notification bell + unread badge -->
                        <Button Classes="win bell" Command="{Binding Notifications.ToggleCenterCommand}"
                                WindowDecorationProperties.ElementRole="User"
                                AutomationProperties.Name="{x:Static lang:Resources.A11y_Notifications}"
                                AutomationProperties.AutomationId="titlebar.notifications">
                            <Grid Width="20" Height="20">
                                <Path Width="15" Height="15" Stretch="Uniform" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" StrokeThickness="1.4"
                                      Data="M8 1 C5 1 4 3 4 6 C4 10 2 11 2 12 H14 C14 11 12 10 12 6 C12 3 11 1 8 1 Z M6.5 14 C6.7 15 7.3 15.5 8 15.5 C8.7 15.5 9.3 15 9.5 14"/>
                                <Border Classes="badge" IsVisible="{Binding Notifications.HasUnread}"
                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0">
                                    <TextBlock Text="{Binding Notifications.UnreadCount}"/>
                                </Border>
                            </Grid>
                        </Button>
                        <Button Classes="win" Click="OnMinimize" AutomationProperties.Name="{x:Static lang:Resources.A11y_Minimize}"
                                WindowDecorationProperties.ElementRole="MinimizeButton">
                            <Path Width="11" Height="11" Stretch="Uniform" StrokeThickness="1.3" Data="M3 8 H13"/>
                        </Button>
                        <Button Classes="win" Click="OnMaxRestore" AutomationProperties.Name="{x:Static lang:Resources.A11y_MaximizeRestore}"
                                WindowDecorationProperties.ElementRole="MaximizeButton">
                            <Path Width="10" Height="10" Stretch="Uniform" StrokeThickness="1.3" Data="M3 3 H13 V13 H3 Z"/>
                        </Button>
                        <Button Classes="win close" Click="OnClose" AutomationProperties.Name="{x:Static lang:Resources.A11y_Close}"
                                WindowDecorationProperties.ElementRole="CloseButton">
                            <Path Width="10" Height="10" Stretch="Uniform" StrokeThickness="1.3"
                                  Data="M3 3 L13 13 M13 3 L3 13"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================ Body ============================ -->
            <Grid ColumnDefinitions="232,Auto,*">

                <!-- Nav rail -->
                <Border Grid.Column="0" Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="0,0,1,0" MinWidth="200" MaxWidth="360">
                    <DockPanel Margin="14,8,14,16">

                        <!-- Connection footer: host + game-data links -->
                        <Border DockPanel.Dock="Bottom" Classes="card" Padding="14,12" Background="#0E1620">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="9">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                             Fill="{Binding HostStatusKind, Converter={StaticResource StatusToBrush}}"/>
                                    <TextBlock Text="{x:Static lang:Resources.Label_App}" Foreground="{StaticResource GlintBrush}" FontSize="12.5"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding HostStateLabel}" Classes="meta" FontSize="10.5"
                                               VerticalAlignment="Center" Margin="2,1,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SatelliteSummary}" Classes="meta" FontSize="10.5"
                                           TextWrapping="Wrap" Foreground="{StaticResource HoarfrostBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Nav items -->
                        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,18,0,0"
                                    AutomationProperties.LandmarkType="Navigation">
                            <TextBlock Text="{x:Static lang:Resources.Eyebrow_Host}" Classes="eyebrow" Margin="8,0,0,10"/>

                            <Button Classes="nav" AutomationProperties.AutomationId="nav.overview"
                                    Classes.active="{Binding CurrentPage.Section, Converter={StaticResource EnumEquals}, ConverterParameter=Overview}"
                                    Command="{Binding SelectPageCommand}" CommandParameter="Overview">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform"
                                              Data="M3 3h7v7H3z M14 3h7v7h-7z M3 14h7v7H3z M14 14h7v7h-7z"/>
                                        <TextBlock Text="{x:Static lang:Resources.Nav_Overview}" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Classes="nav" AutomationProperties.AutomationId="nav.plugins"
                                    Classes.active="{Binding CurrentPage.Section, Converter={StaticResource EnumEquals}, ConverterParameter=Plugins}"
                                    Command="{Binding SelectPageCommand}" CommandParameter="Plugins">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform" Data="M12 2 L20 9 L12 22 L4 9 Z"/>
                                        <TextBlock Text="{x:Static lang:Resources.Nav_Plugins}" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Classes="nav" AutomationProperties.AutomationId="nav.encounters"
                                    Classes.active="{Binding CurrentPage.Section, Converter={StaticResource EnumEquals}, ConverterParameter=Encounters}"
                                    Command="{Binding SelectPageCommand}" CommandParameter="Encounters">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform"
                                              Data="M3 20 V11 H6 V20 Z M9.5 20 V4 H12.5 V20 Z M16 20 V14 H19 V20 Z"/>
                                        <TextBlock Text="{x:Static lang:Resources.Nav_Encounters}" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Classes="nav" AutomationProperties.AutomationId="nav.settings"
                                    Classes.active="{Binding CurrentPage.Section, Converter={StaticResource EnumEquals}, ConverterParameter=Settings}"
                                    Command="{Binding SelectPageCommand}" CommandParameter="Settings">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform"
                                              Data="M19.14 12.94a7.5 7.5 0 0 0 0-1.88l2.03-1.58a.5.5 0 0 0 .12-.64l-1.92-3.32a.5.5 0 0 0-.61-.22l-2.39.96a7.3 7.3 0 0 0-1.62-.94l-.36-2.54a.5.5 0 0 0-.5-.42h-3.84a.5.5 0 0 0-.5.42l-.36 2.54c-.59.24-1.13.56-1.62.94l-2.39-.96a.5.5 0 0 0-.61.22L2.7 8.84a.5.5 0 0 0 .12.64l2.03 1.58a7.5 7.5 0 0 0 0 1.88L2.82 14.52a.5.5 0 0 0-.12.64l1.92 3.32a.5.5 0 0 0 .61.22l2.39-.96c.49.38 1.03.7 1.62.94l.36 2.54a.5.5 0 0 0 .5.42h3.84a.5.5 0 0 0 .5-.42l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96a.5.5 0 0 0 .61-.22l1.92-3.32a.5.5 0 0 0-.12-.64zM12 15.5A3.5 3.5 0 1 1 12 8.5a3.5 3.5 0 0 1 0 7z"/>
                                        <TextBlock Text="{x:Static lang:Resources.Nav_Settings}" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Resizable divider between the nav rail and the content pane -->
                <GridSplitter Grid.Column="1" Classes="pane" ResizeDirection="Columns"/>

                <!-- Content + status bar -->
                <Grid Grid.Column="2" RowDefinitions="*,Auto">
                    <Grid Grid.Row="0" Margin="34,18,34,16" RowDefinitions="Auto,*"
                          AutomationProperties.LandmarkType="Main">

                        <!-- Shared content header (pages with their own chrome hide it) -->
                        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,20"
                                    IsVisible="{Binding CurrentPage.ShowGenericHeader}">
                            <TextBlock Text="{Binding CurrentPage.Eyebrow}" Classes="eyebrow"/>
                            <TextBlock Text="{Binding CurrentPage.Title}" Classes="h1"/>
                            <TextBlock Text="{Binding CurrentPage.Subtitle}" Classes="subtitle" MaxWidth="620"
                                       HorizontalAlignment="Left"/>
                            <Border Classes="rule" Width="64" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                        </StackPanel>

                        <ContentControl Grid.Row="1" Content="{Binding CurrentPage}"/>
                    </Grid>

                    <!-- ============================ Status bar ============================ -->
                    <Border Grid.Row="1" Classes="statusbar">
                        <Grid Margin="34,0" ColumnDefinitions="*,Auto">
                            <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                             Fill="{Binding HostStatusKind, Converter={StaticResource StatusToBrush}}"/>
                                    <TextBlock Text="{x:Static lang:Resources.Status_AppRunning}" Classes="statusitem"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding LoadedSummary}" Classes="statusitem"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </DockPanel>

        <!-- ============================ Notification overlay ============================ -->
        <!-- Scrim closes the drawer on outside click -->
        <Rectangle Fill="#6605080C" IsVisible="{Binding Notifications.IsOpen}"
                   PointerPressed="OnScrimPressed"/>

        <!-- Notification centre drawer -->
        <Border Classes="drawer" IsVisible="{Binding Notifications.IsOpen}"
                HorizontalAlignment="Right" Width="380">
            <DockPanel Margin="0">
                <Grid DockPanel.Dock="Top" Margin="22,20,16,14" ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static lang:Resources.NotificationCenter_Title}" Classes="h2"/>
                        <TextBlock Text="{x:Static lang:Resources.NotificationCenter_Subtitle}" Classes="meta" FontSize="11"/>
                    </StackPanel>
                    <Button Grid.Column="1" Classes="ghost small" Content="{x:Static lang:Resources.Action_Clear}" VerticalAlignment="Center"
                            IsVisible="{Binding Notifications.HasHistory}"
                            Command="{Binding Notifications.ClearHistoryCommand}"/>
                    <Button Grid.Column="2" Classes="iconbtn" VerticalAlignment="Center" Margin="6,0,0,0"
                            AutomationProperties.Name="{x:Static lang:Resources.A11y_CloseNotifications}"
                            Command="{Binding Notifications.CloseCenterCommand}">
                        <Path Width="11" Height="11" Stretch="Uniform" StrokeThickness="1.5"
                              Data="M2 2 L11 11 M11 2 L2 11"/>
                    </Button>
                </Grid>

                <!-- Empty state -->
                <StackPanel IsVisible="{Binding !Notifications.HasHistory}"
                            VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Margin="24">
                    <Path Width="30" Height="30" Stretch="Uniform" Opacity="0.4"
                          Fill="{StaticResource HoarfrostBrush}"
                          Data="M8 1 C5 1 4 3 4 6 C4 10 2 11 2 12 H14 C14 11 12 10 12 6 C12 3 11 1 8 1 Z"/>
                    <TextBlock Text="{x:Static lang:Resources.NotificationCenter_EmptyTitle}" Classes="meta" HorizontalAlignment="Center"/>
                    <TextBlock Text="{x:Static lang:Resources.NotificationCenter_EmptyBody}" Classes="meta" FontSize="11"
                               TextAlignment="Center" MaxWidth="220"/>
                </StackPanel>

                <ScrollViewer IsVisible="{Binding Notifications.HasHistory}" Padding="16,0,16,16">
                    <ItemsControl ItemsSource="{Binding Notifications.History}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:NotificationViewModel">
                                <Border Classes="noticerow">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border Grid.Column="0" Width="26" Height="26" CornerRadius="13"
                                                VerticalAlignment="Top" Margin="0,1,12,0"
                                                Background="{Binding Severity, Converter={StaticResource SeverityToBrush}, ConverterParameter=glow}">
                                            <Path Width="13" Height="13" Stretch="Uniform" StrokeThickness="1.5"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Data="{Binding IconData}"
                                                  Stroke="{Binding Severity, Converter={StaticResource SeverityToBrush}}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource GlintBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Grid.Column="1" Text="{Binding TimeLabel}" Classes="meta"
                                                           FontSize="10.5" VerticalAlignment="Top" Margin="8,2,0,0"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Message}" Classes="meta" FontSize="11"
                                                       TextWrapping="Wrap" IsVisible="{Binding HasMessage}"/>
                                            <TextBlock Text="{Binding Source}" Classes="eyebrow" FontSize="9.5"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Corner controls: transient plugin overlays (Triggernometry's CornerControlAdd, work item 9) -->
        <ItemsControl ItemsSource="{Binding CornerControls}" HorizontalAlignment="Right"
                      VerticalAlignment="Top" Margin="0,54,20,0" Width="320" IsHitTestVisible="True">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:CornerControlViewModel">
                    <Border Classes="toast rise1" Margin="0,0,0,8">
                        <views:PluginSurfaceView Surface="{Binding Surface}"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Toast host -->
        <ItemsControl ItemsSource="{Binding Notifications.Toasts}" HorizontalAlignment="Right"
                      VerticalAlignment="Bottom" Margin="0,0,20,44" Width="340" IsHitTestVisible="True">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:NotificationViewModel">
                    <Border Classes="toast rise1">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" VerticalAlignment="Top"
                                    Margin="0,1,11,0"
                                    Background="{Binding Severity, Converter={StaticResource SeverityToBrush}, ConverterParameter=glow}">
                                <Path Width="12" Height="12" Stretch="Uniform" StrokeThickness="1.5"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="{Binding IconData}"
                                      Stroke="{Binding Severity, Converter={StaticResource SeverityToBrush}}"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource GlintBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Message}" Classes="meta" FontSize="11" TextWrapping="Wrap"
                                           MaxLines="3" TextTrimming="CharacterEllipsis" IsVisible="{Binding HasMessage}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Classes="iconbtn" VerticalAlignment="Top"
                                    AutomationProperties.Name="{x:Static lang:Resources.A11y_DismissNotification}"
                                    Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).Notifications.DismissToastCommand}"
                                    CommandParameter="{Binding}">
                                <Path Width="9" Height="9" Stretch="Uniform" StrokeThickness="1.5"
                                      Data="M2 2 L9 9 M9 2 L2 9"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
