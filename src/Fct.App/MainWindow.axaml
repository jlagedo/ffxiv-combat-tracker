<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Fct.App.ViewModels"
        xmlns:views="using:Fct.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="Fct.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="FFXIV Combat Tracker"
        Width="1180" Height="760" MinWidth="980" MinHeight="640"
        FontFamily="{StaticResource BodyFont}"
        Background="{StaticResource AbyssBrush}"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True">

    <!-- Each content page maps to its view; the shell swaps CurrentPage. -->
    <Window.DataTemplates>
        <DataTemplate DataType="vm:DashboardViewModel"><views:DashboardView/></DataTemplate>
        <DataTemplate DataType="vm:PluginsViewModel"><views:PluginsView/></DataTemplate>
        <DataTemplate DataType="vm:OverlaysViewModel"><views:OverlaysView/></DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel"><views:SettingsView/></DataTemplate>
    </Window.DataTemplates>

    <Grid>
        <!-- Frozen atmosphere: cold vertical wash + a faint crystal-needle fan at the crown -->
        <Rectangle Fill="{StaticResource AtmosphereBrush}"/>
        <Path Classes="crownfan" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-30,0,0"
              Width="600" Stretch="Uniform" Opacity="0.06" Fill="{StaticResource FrostBrush}"
              Data="M260 0 L268 220 L276 0 Z M222 26 L264 210 L238 24 Z M298 26 L266 210 L282 24 Z M186 64 L260 200 L208 60 Z M334 64 L270 200 L312 60 Z M150 104 L256 188 L182 100 Z M370 104 L274 188 L338 100 Z"/>

        <DockPanel>
            <!-- ============================ Title bar ============================
                 ElementRole=TitleBar hands dragging + double-click-maximize to the OS
                 (Avalonia 12); interactive controls inside still receive input. -->
            <Border DockPanel.Dock="Top" Height="46" Background="Transparent"
                    Name="TitleBar" WindowDecorationProperties.ElementRole="TitleBar">
                <Grid Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="11">
                        <Path Width="16" Height="16" Stretch="Uniform" Fill="{StaticResource FrostBrush}"
                              Data="M11 1 L20 9 L11 22 L2 9 Z"/>
                        <TextBlock Text="FFXIV" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                   LetterSpacing="3" Foreground="{StaticResource FrostBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Width="1" Height="14" Background="{StaticResource HairlineBrush}"/>
                        <TextBlock Text="COMBAT TRACKER" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="14" LetterSpacing="2" Foreground="{StaticResource GlintBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Classes="win" Click="OnMinimize" AutomationProperties.Name="Minimize"
                                WindowDecorationProperties.ElementRole="MinimizeButton">
                            <Path Width="11" Height="11" Stretch="Uniform" StrokeThickness="1.3"
                                  Data="M3 8 H13"/>
                        </Button>
                        <Button Classes="win" Click="OnMaxRestore" AutomationProperties.Name="Maximize or restore"
                                WindowDecorationProperties.ElementRole="MaximizeButton">
                            <Path Width="10" Height="10" Stretch="Uniform" StrokeThickness="1.3"
                                  Data="M3 3 H13 V13 H3 Z"/>
                        </Button>
                        <Button Classes="win close" Click="OnClose" AutomationProperties.Name="Close"
                                WindowDecorationProperties.ElementRole="CloseButton">
                            <Path Width="10" Height="10" Stretch="Uniform" StrokeThickness="1.3"
                                  Data="M3 3 L13 13 M13 3 L3 13"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================ Body ============================ -->
            <Grid ColumnDefinitions="232,Auto,*">

                <!-- Nav rail -->
                <Border Grid.Column="0" Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="0,0,1,0" MinWidth="200" MaxWidth="360">
                    <DockPanel Margin="14,8,14,16">

                        <!-- Satellite status footer -->
                        <Border DockPanel.Dock="Bottom" Classes="card" Padding="14,12" Background="#0E1620">
                            <StackPanel Spacing="9">
                                <StackPanel Orientation="Horizontal" Spacing="9">
                                    <Grid Width="14" Height="14" VerticalAlignment="Center">
                                        <Ellipse Classes="pulse" Width="14" Height="14" Opacity="0.30"
                                                 Fill="{Binding SatelliteState, Converter={StaticResource StatusToBrush}}"/>
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{Binding SatelliteState, Converter={StaticResource StatusToBrush}}"/>
                                    </Grid>
                                    <TextBlock Text="Satellite" Foreground="{StaticResource GlintBrush}"
                                               FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SatelliteState}" Classes="meta"
                                               VerticalAlignment="Center" Margin="2,1,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SatelliteSummary}" Classes="meta" FontSize="11"
                                           TextWrapping="Wrap" Foreground="{StaticResource HoarfrostBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Nav items -->
                        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,18,0,0"
                                    AutomationProperties.LandmarkType="Navigation">
                            <TextBlock Text="HOST" Classes="eyebrow" Margin="8,0,0,10"/>

                            <Button Classes="nav" AutomationProperties.AutomationId="nav.dashboard"
                                    Classes.active="{Binding CurrentPage.Section, Converter={StaticResource EnumEquals}, ConverterParameter=Dashboard}"
                                    Command="{Binding SelectPageCommand}" CommandParameter="Dashboard">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform"
                                              Data="M3 3h7v7H3z M14 3h7v7h-7z M3 14h7v7H3z M14 14h7v7h-7z"/>
                                        <TextBlock Text="Dashboard" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Classes="nav" AutomationProperties.AutomationId="nav.plugins"
                                    Classes.active="{Binding CurrentPage.Section, Converter={StaticResource EnumEquals}, ConverterParameter=Plugins}"
                                    Command="{Binding SelectPageCommand}" CommandParameter="Plugins">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform" Data="M12 2 L20 9 L12 22 L4 9 Z"/>
                                        <TextBlock Text="Plugins" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Classes="nav" AutomationProperties.AutomationId="nav.overlays"
                                    Classes.active="{Binding CurrentPage.Section, Converter={StaticResource EnumEquals}, ConverterParameter=Overlays}"
                                    Command="{Binding SelectPageCommand}" CommandParameter="Overlays">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform"
                                              Data="M4 4h16v5H4z M4 11h16v3H4z M4 16h16v3H4z"/>
                                        <TextBlock Text="Overlays" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Classes="nav" AutomationProperties.AutomationId="nav.settings"
                                    Classes.active="{Binding CurrentPage.Section, Converter={StaticResource EnumEquals}, ConverterParameter=Settings}"
                                    Command="{Binding SelectPageCommand}" CommandParameter="Settings">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform"
                                              Data="M19.14 12.94a7.5 7.5 0 0 0 0-1.88l2.03-1.58a.5.5 0 0 0 .12-.64l-1.92-3.32a.5.5 0 0 0-.61-.22l-2.39.96a7.3 7.3 0 0 0-1.62-.94l-.36-2.54a.5.5 0 0 0-.5-.42h-3.84a.5.5 0 0 0-.5.42l-.36 2.54c-.59.24-1.13.56-1.62.94l-2.39-.96a.5.5 0 0 0-.61.22L2.7 8.84a.5.5 0 0 0 .12.64l2.03 1.58a7.5 7.5 0 0 0 0 1.88L2.82 14.52a.5.5 0 0 0-.12.64l1.92 3.32a.5.5 0 0 0 .61.22l2.39-.96c.49.38 1.03.7 1.62.94l.36 2.54a.5.5 0 0 0 .5.42h3.84a.5.5 0 0 0 .5-.42l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96a.5.5 0 0 0 .61-.22l1.92-3.32a.5.5 0 0 0-.12-.64zM12 15.5A3.5 3.5 0 1 1 12 8.5a3.5 3.5 0 0 1 0 7z"/>
                                        <TextBlock Text="Settings" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Resizable divider between the nav rail and the content pane -->
                <GridSplitter Grid.Column="1" Classes="pane" ResizeDirection="Columns"/>

                <!-- Content -->
                <Grid Grid.Column="2" Margin="34,18,34,28" RowDefinitions="Auto,*"
                      AutomationProperties.LandmarkType="Main">

                    <!-- Shared content header (pages with their own chrome hide it) -->
                    <Grid Grid.Row="0" Margin="0,0,0,22" IsVisible="{Binding CurrentPage.ShowGenericHeader}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding CurrentPage.Eyebrow}" Classes="eyebrow"/>
                            <TextBlock Text="{Binding CurrentPage.Title}" Classes="h1"/>
                            <TextBlock Text="{Binding CurrentPage.Subtitle}" Classes="subtitle" MaxWidth="620"
                                       HorizontalAlignment="Left"/>
                            <Border Classes="rule" Width="64" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Host pill -->
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="#0E1620" BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="20" Padding="14,7">
                            <StackPanel Orientation="Horizontal" Spacing="9">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                         Fill="{Binding SatelliteState, Converter={StaticResource StatusToBrush}}"/>
                                <TextBlock Text="{Binding SatelliteState}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="12" Foreground="{StaticResource GlintBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Active page -->
                    <ContentControl Grid.Row="1" Content="{Binding CurrentPage}"/>

                </Grid>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
