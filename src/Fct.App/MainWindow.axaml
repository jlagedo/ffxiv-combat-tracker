<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Fct.App.MainWindow"
        Title="FFXIV Combat Tracker"
        Width="640" Height="360">
    <StackPanel Margin="24" Spacing="10">
        <TextBlock Text="FFXIV Combat Tracker — host shell" FontSize="20" FontWeight="Bold"/>
        <TextBlock Text="net10 Avalonia host (Fct.App)" Opacity="0.7"/>
        <Border Background="#11000000" CornerRadius="6" Padding="12">
            <TextBlock x:Name="StatusText" Text="Starting satellite…" TextWrapping="Wrap" FontFamily="Cascadia Mono,Consolas,monospace"/>
        </Border>
    </StackPanel>
</Window>
