<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Fct.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="Fct.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="FFXIV Combat Tracker"
        Width="1180" Height="760" MinWidth="980" MinHeight="640"
        FontFamily="{StaticResource BodyFont}"
        Background="{StaticResource AbyssBrush}"
        WindowDecorations="BorderOnly">

    <Grid>
        <!-- Frozen atmosphere: cold vertical wash + a faint crystal-needle fan at the crown -->
        <Rectangle Fill="{StaticResource AtmosphereBrush}"/>
        <Path VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-30,0,0"
              Width="600" Stretch="Uniform" Opacity="0.06" Fill="{StaticResource FrostBrush}"
              Data="M260 0 L268 220 L276 0 Z M222 26 L264 210 L238 24 Z M298 26 L266 210 L282 24 Z M186 64 L260 200 L208 60 Z M334 64 L270 200 L312 60 Z M150 104 L256 188 L182 100 Z M370 104 L274 188 L338 100 Z"/>

        <DockPanel>
            <!-- ============================ Title bar ============================ -->
            <Border DockPanel.Dock="Top" Height="46" Background="Transparent"
                    Name="TitleBar" PointerPressed="OnTitleBarPressed">
                <Grid Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="11">
                        <Path Width="16" Height="16" Stretch="Uniform" Fill="{StaticResource FrostBrush}"
                              Data="M11 1 L20 9 L11 22 L2 9 Z"/>
                        <TextBlock Text="FFXIV" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                   LetterSpacing="3" Foreground="{StaticResource FrostBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Width="1" Height="14" Background="{StaticResource HairlineBrush}"/>
                        <TextBlock Text="COMBAT TRACKER" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="14" LetterSpacing="2" Foreground="{StaticResource GlintBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Classes="win" Click="OnMinimize">
                            <Path Width="11" Height="11" Stretch="Uniform" StrokeThickness="1.3"
                                  Data="M3 8 H13"/>
                        </Button>
                        <Button Classes="win" Click="OnMaxRestore">
                            <Path Width="10" Height="10" Stretch="Uniform" StrokeThickness="1.3"
                                  Data="M3 3 H13 V13 H3 Z"/>
                        </Button>
                        <Button Classes="win close" Click="OnClose">
                            <Path Width="10" Height="10" Stretch="Uniform" StrokeThickness="1.3"
                                  Data="M3 3 L13 13 M13 3 L3 13"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================ Body ============================ -->
            <Grid ColumnDefinitions="232,*">

                <!-- Nav rail -->
                <Border Grid.Column="0" Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                        BorderThickness="0,0,1,0">
                    <DockPanel Margin="14,8,14,16">

                        <!-- Satellite status footer -->
                        <Border DockPanel.Dock="Bottom" Classes="card" Padding="14,12" Background="#0E1620">
                            <StackPanel Spacing="9">
                                <StackPanel Orientation="Horizontal" Spacing="9">
                                    <Grid Width="14" Height="14" VerticalAlignment="Center">
                                        <Ellipse Width="14" Height="14" Opacity="0.30"
                                                 Fill="{Binding SatelliteState, Converter={StaticResource StatusToBrush}}"/>
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{Binding SatelliteState, Converter={StaticResource StatusToBrush}}"/>
                                    </Grid>
                                    <TextBlock Text="Satellite" Foreground="{StaticResource GlintBrush}"
                                               FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SatelliteState}" Classes="meta"
                                               VerticalAlignment="Center" Margin="2,1,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SatelliteSummary}" Classes="meta" FontSize="11"
                                           TextWrapping="Wrap" Foreground="{StaticResource HoarfrostBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Nav items -->
                        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,18,0,0">
                            <TextBlock Text="HOST" Classes="eyebrow" Margin="8,0,0,10"/>

                            <Button Classes="nav"
                                    Classes.active="{Binding SelectedSection, Converter={StaticResource StringEquals}, ConverterParameter=Dashboard}"
                                    Command="{Binding SelectSectionCommand}" CommandParameter="Dashboard">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform"
                                              Data="M3 3h7v7H3z M14 3h7v7h-7z M3 14h7v7H3z M14 14h7v7h-7z"/>
                                        <TextBlock Text="Dashboard" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Classes="nav"
                                    Classes.active="{Binding SelectedSection, Converter={StaticResource StringEquals}, ConverterParameter=Plugins}"
                                    Command="{Binding SelectSectionCommand}" CommandParameter="Plugins">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform" Data="M12 2 L20 9 L12 22 L4 9 Z"/>
                                        <TextBlock Text="Plugins" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Classes="nav"
                                    Classes.active="{Binding SelectedSection, Converter={StaticResource StringEquals}, ConverterParameter=Overlays}"
                                    Command="{Binding SelectSectionCommand}" CommandParameter="Overlays">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform"
                                              Data="M4 4h16v5H4z M4 11h16v3H4z M4 16h16v3H4z"/>
                                        <TextBlock Text="Overlays" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <Button Classes="nav"
                                    Classes.active="{Binding SelectedSection, Converter={StaticResource StringEquals}, ConverterParameter=Settings}"
                                    Command="{Binding SelectSectionCommand}" CommandParameter="Settings">
                                <Grid>
                                    <Rectangle Classes="navbar" Width="3" Height="18" Fill="{StaticResource FrostBrush}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center" RadiusX="2" RadiusY="2"/>
                                    <StackPanel Orientation="Horizontal" Spacing="13" Margin="16,11">
                                        <Path Width="17" Height="17" Stretch="Uniform"
                                              Data="M19.14 12.94a7.5 7.5 0 0 0 0-1.88l2.03-1.58a.5.5 0 0 0 .12-.64l-1.92-3.32a.5.5 0 0 0-.61-.22l-2.39.96a7.3 7.3 0 0 0-1.62-.94l-.36-2.54a.5.5 0 0 0-.5-.42h-3.84a.5.5 0 0 0-.5.42l-.36 2.54c-.59.24-1.13.56-1.62.94l-2.39-.96a.5.5 0 0 0-.61.22L2.7 8.84a.5.5 0 0 0 .12.64l2.03 1.58a7.5 7.5 0 0 0 0 1.88L2.82 14.52a.5.5 0 0 0-.12.64l1.92 3.32a.5.5 0 0 0 .61.22l2.39-.96c.49.38 1.03.7 1.62.94l.36 2.54a.5.5 0 0 0 .5.42h3.84a.5.5 0 0 0 .5-.42l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96a.5.5 0 0 0 .61-.22l1.92-3.32a.5.5 0 0 0-.12-.64zM12 15.5A3.5 3.5 0 1 1 12 8.5a3.5 3.5 0 0 1 0 7z"/>
                                        <TextBlock Text="Settings" FontSize="13.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Content -->
                <Grid Grid.Column="1" Margin="34,18,34,28" RowDefinitions="Auto,*">

                    <!-- Content header (the Plugins page supplies its own compact chrome) -->
                    <Grid Grid.Row="0" Margin="0,0,0,22" IsVisible="{Binding ShowGenericHeader}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding SelectedSection}" Classes="eyebrow"/>
                            <TextBlock Classes="h1" Name="HeaderTitle"/>
                            <TextBlock Classes="subtitle" Name="HeaderSubtitle" MaxWidth="620"
                                       HorizontalAlignment="Left"/>
                            <Border Classes="rule" Width="64" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Host pill -->
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="#0E1620" BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="20" Padding="14,7">
                            <StackPanel Orientation="Horizontal" Spacing="9">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                         Fill="{Binding SatelliteState, Converter={StaticResource StatusToBrush}}"/>
                                <TextBlock Text="{Binding SatelliteState}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="12" Foreground="{StaticResource GlintBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ===================== PLUGINS ===================== -->
                    <Grid Grid.Row="1"
                          IsVisible="{Binding SelectedSection, Converter={StaticResource StringEquals}, ConverterParameter=Plugins}"
                          RowDefinitions="Auto,Auto,*">

                        <!-- Compact page chrome (the shared header is hidden on this page) -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="PLUGINS" Classes="eyebrow"/>
                                <TextBlock Text="Plugin Setup" Classes="h2" FontSize="21"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="#0E1620" BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1" CornerRadius="20" Padding="14,7">
                                <StackPanel Orientation="Horizontal" Spacing="9">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                             Fill="{Binding SatelliteState, Converter={StaticResource StatusToBrush}}"/>
                                    <TextBlock Text="{Binding SatelliteState}" FontFamily="{StaticResource MonoFont}"
                                               FontSize="12" Foreground="{StaticResource GlintBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Error banner -->
                        <Border Grid.Row="1" IsVisible="{Binding HasError}" Margin="0,0,0,16"
                                Background="#241317" BorderBrush="{StaticResource WarnBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="18,14">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="The host could not start the satellite"
                                               Foreground="{StaticResource GlintBrush}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ErrorMessage}" Classes="meta" FontSize="11.5"
                                               TextWrapping="Wrap" MaxWidth="700" HorizontalAlignment="Left"/>
                                </StackPanel>
                                <Button Grid.Column="1" Classes="ghost" Content="Retry" VerticalAlignment="Center"
                                        Command="{Binding RetryCommand}"/>
                            </Grid>
                        </Border>

                        <!-- Channel rail + bay -->
                        <Grid Grid.Row="2" ColumnDefinitions="212,18,*">

                            <!-- ===== Channel rail: quick switch between plugins ===== -->
                            <Border Grid.Column="0" Classes="card" Padding="0">
                                <DockPanel Margin="10">
                                    <Grid DockPanel.Dock="Top" Margin="6,6,6,12">
                                        <TextBlock Text="CHANNELS" Classes="eyebrow" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding LoadedCount}" Classes="meta" FontSize="11"
                                                   Foreground="{StaticResource FrostBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Button DockPanel.Dock="Bottom" Classes="railmanage" Margin="0,10,0,0"
                                            Classes.active="{Binding IsManage}" Command="{Binding ManageCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="11" Margin="13,0">
                                            <Path Width="14" Height="14" Stretch="Uniform" StrokeThickness="1.6"
                                                  Data="M8 1 V15 M1 8 H15"/>
                                            <TextBlock Text="Manage plugins" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                        <ListBox Classes="rail" ItemsSource="{Binding Plugins}"
                                                 SelectedItem="{Binding SelectedPlugin, Mode=TwoWay}"
                                                 Tapped="OnRailTapped">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PluginViewModel">
                                                    <Border Classes="railcard">
                                                        <Grid ColumnDefinitions="Auto,Auto,*">
                                                            <Rectangle Grid.Column="0" Classes="railbar" Width="3" Height="26"
                                                                       Fill="{StaticResource FrostBrush}" RadiusX="2" RadiusY="2"
                                                                       VerticalAlignment="Center" Margin="0,0,11,0"/>
                                                            <Grid Grid.Column="1" Width="18" Height="18" VerticalAlignment="Center"
                                                                  Margin="0,0,11,0">
                                                                <Border Width="18" Height="18" CornerRadius="9"
                                                                        Classes.pulse="{Binding IsLive}"
                                                                        Background="{Binding Status, Converter={StaticResource StatusToBrush}, ConverterParameter=glow}"/>
                                                                <Ellipse Width="8" Height="8"
                                                                         Fill="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                                            </Grid>
                                                            <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource GlintBrush}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding StatusLabel}"
                                                                           FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>

                            <!-- ===== Bay: Configure (the plugin's own tabs, full surface) ===== -->
                            <Border Grid.Column="2" Classes="card" Padding="0" IsVisible="{Binding IsConfigure}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="0,0,0,1" Padding="20,15">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Grid Grid.Column="0" Width="26" Height="26" VerticalAlignment="Center" Margin="0,0,13,0">
                                                <Border Width="26" Height="26" CornerRadius="13"
                                                        Classes.pulse="{Binding SelectedPlugin.IsLive}"
                                                        Background="{Binding SelectedPlugin.Status, Converter={StaticResource StatusToBrush}, ConverterParameter=glow}"/>
                                                <Ellipse Width="11" Height="11"
                                                         Fill="{Binding SelectedPlugin.Status, Converter={StaticResource StatusToBrush}}"/>
                                            </Grid>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SelectedPlugin.Name}" Classes="h2"/>
                                                <TextBlock Text="{Binding SelectedPlugin.Role}" Classes="meta" FontSize="11"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                <Border Background="{StaticResource RimeBrush}" CornerRadius="6" Padding="10,5">
                                                    <TextBlock Text="{Binding SelectedPlugin.Runtime}"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                               Foreground="{StaticResource FrostBrush}"/>
                                                </Border>
                                                <TextBlock Text="{Binding SelectedPlugin.StatusLabel}"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="11.5"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding SelectedPlugin.Status, Converter={StaticResource StatusToBrush}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Grid Margin="16">
                                        <!-- Native (legacy) plugin config tabs -->
                                        <Grid IsVisible="{Binding SelectedPlugin.HasNativeConfig}">
                                            <!-- Embedded foreign HWND lands here once the satellite is up -->
                                            <Border Name="EmbedSlot" IsVisible="{Binding ConfigReady}"
                                                    Background="#070A0E" BorderBrush="{StaticResource HairlineBrush}"
                                                    BorderThickness="1" CornerRadius="10" ClipToBounds="True"/>
                                            <!-- Not-ready note -->
                                            <Border IsVisible="{Binding ConfigReady, Converter={StaticResource InverseBool}}"
                                                    Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                                                    BorderThickness="1" CornerRadius="10">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                                    <Path Width="34" Height="34" Stretch="Uniform" Opacity="0.5"
                                                          Fill="{StaticResource HoarfrostBrush}" Data="M12 2 L20 9 L12 22 L4 9 Z"/>
                                                    <TextBlock Text="Configuration loads when the host is online"
                                                               Classes="meta" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <!-- Preview / native plugin (no legacy tabs) -->
                                        <Border IsVisible="{Binding SelectedPlugin.HasNativeConfig, Converter={StaticResource InverseBool}}"
                                                Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                                                BorderThickness="1" CornerRadius="10">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" MaxWidth="420">
                                                <Path Width="40" Height="40" Stretch="Uniform" Opacity="0.6"
                                                      Fill="{StaticResource FrostDimBrush}" Data="M12 2 L20 9 L12 22 L4 9 Z"/>
                                                <TextBlock Text="{Binding SelectedPlugin.ConfigPlaceholderTitle}" Classes="h2" HorizontalAlignment="Center"/>
                                                <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Classes="subtitle"
                                                           Text="{Binding SelectedPlugin.ConfigPlaceholderBody}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DockPanel>
                            </Border>

                            <!-- ===== Bay: Manage (add / remove / enable / reorder) ===== -->
                            <Border Grid.Column="2" Classes="card" Padding="0" IsVisible="{Binding IsManage}">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" Margin="22,18,22,16" ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Text="Installed plugins" Classes="h2"/>
                                            <TextBlock Text="{Binding LoadedSummary}" Classes="meta" FontSize="11"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Classes="ghost" VerticalAlignment="Center"
                                                Command="{Binding AddPluginCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Path Width="12" Height="12" Stretch="Uniform" Stroke="{StaticResource FrostBrush}"
                                                      StrokeThickness="1.6" Data="M7 1 V13 M1 7 H13"/>
                                                <TextBlock Text="Add plugin"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource HairlineBrush}"
                                            BorderThickness="0,1,0,0" Padding="22,12">
                                        <TextBlock Classes="meta" FontSize="11" TextWrapping="Wrap"
                                                   Text="The .NET 4.8 satellite loads plugins at startup. Enabling, reordering, and newly added plugins take effect on the next host launch."/>
                                    </Border>

                                    <ScrollViewer Padding="22,4,22,12">
                                        <ItemsControl ItemsSource="{Binding Plugins}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PluginViewModel">
                                                    <Border Classes="rackrow">
                                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                                                            <!-- reorder -->
                                                            <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center" Margin="0,0,12,0">
                                                                <Button Classes="iconbtn"
                                                                        Command="{Binding ((vm:MainViewModel)DataContext).MoveUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Path Width="10" Height="6" Stretch="Uniform"
                                                                          StrokeThickness="1.5" Data="M1 6 L6 1 L11 6"/>
                                                                </Button>
                                                                <Button Classes="iconbtn"
                                                                        Command="{Binding ((vm:MainViewModel)DataContext).MoveDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Path Width="10" Height="6" Stretch="Uniform"
                                                                          StrokeThickness="1.5" Data="M1 1 L6 6 L11 1"/>
                                                                </Button>
                                                            </StackPanel>
                                                            <!-- status orb -->
                                                            <Grid Grid.Column="1" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,13,0">
                                                                <Border Width="20" Height="20" CornerRadius="10"
                                                                        Background="{Binding Status, Converter={StaticResource StatusToBrush}, ConverterParameter=glow}"/>
                                                                <Ellipse Width="9" Height="9"
                                                                         Fill="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                                            </Grid>
                                                            <!-- identity -->
                                                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource GlintBrush}" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Classes="meta" FontSize="11" TextTrimming="CharacterEllipsis"
                                                                           Text="{Binding Role}"/>
                                                            </StackPanel>
                                                            <!-- status + enable -->
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12"
                                                                        VerticalAlignment="Center" Margin="12,0">
                                                                <TextBlock Text="{Binding StatusLabel}" VerticalAlignment="Center"
                                                                           FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                                                <ToggleSwitch OnContent="" OffContent="" VerticalAlignment="Center"
                                                                              IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                                              IsEnabled="{Binding CanToggle}"/>
                                                            </StackPanel>
                                                            <!-- remove -->
                                                            <Button Grid.Column="4" Classes="iconbtn danger" VerticalAlignment="Center"
                                                                    Command="{Binding ((vm:MainViewModel)DataContext).RemovePluginCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Path Width="11" Height="11" Stretch="Uniform"
                                                                      StrokeThickness="1.5" Data="M2 2 L11 11 M11 2 L2 11"/>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ===================== DASHBOARD ===================== -->
                    <ScrollViewer Grid.Row="1"
                                  IsVisible="{Binding SelectedSection, Converter={StaticResource StringEquals}, ConverterParameter=Dashboard}">
                        <StackPanel Spacing="18">
                            <Grid ColumnDefinitions="*,16,*,16,*,16,*">
                                <Border Grid.Column="0" Classes="card" Padding="18,16">
                                    <StackPanel Spacing="7">
                                        <TextBlock Text="HOST" Classes="eyebrow"/>
                                        <TextBlock Text=".NET 10" Classes="h2" FontSize="24"/>
                                        <TextBlock Text="Avalonia shell" Classes="meta" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Classes="card" Padding="18,16">
                                    <StackPanel Spacing="7">
                                        <TextBlock Text="SATELLITE" Classes="eyebrow"/>
                                        <TextBlock Text="{Binding SatelliteState}" Classes="h2" FontSize="24"
                                                   Foreground="{Binding SatelliteState, Converter={StaticResource StatusToBrush}}"/>
                                        <TextBlock Text="{Binding SatelliteSummary}" Classes="meta" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4" Classes="card" Padding="18,16">
                                    <StackPanel Spacing="7">
                                        <TextBlock Text="PLUGINS" Classes="eyebrow"/>
                                        <TextBlock Text="{Binding LoadedCount}" Classes="h2" FontSize="24"/>
                                        <TextBlock Text="{Binding LoadedSummary}" Classes="meta" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="6" Classes="card" Padding="18,16">
                                    <StackPanel Spacing="7">
                                        <TextBlock Text="DATA SOURCE" Classes="eyebrow"/>
                                        <TextBlock Text="{Binding SelectedPlugin.StatusLabel}" Classes="h2" FontSize="24"/>
                                        <TextBlock Text="FFXIV_ACT_Plugin" Classes="meta" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Classes="card" Padding="26,24">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="Welcome to the host" Classes="h2"/>
                                    <Border Classes="rule" Width="64" HorizontalAlignment="Left"/>
                                    <TextBlock Classes="body" MaxWidth="720" HorizontalAlignment="Left"
                                               Text="The host runs the legacy plugin ecosystem unmodified — FFXIV_ACT_Plugin, OverlayPlugin, Triggernometry, and Discord triggers — inside a .NET Framework 4.8 satellite, while the shell you're looking at runs on .NET 10. Head to Plugins to enable each one and open its configuration in place."/>
                                    <Button Classes="ghost" Content="Configure plugins" HorizontalAlignment="Left"
                                            Command="{Binding SelectSectionCommand}" CommandParameter="Plugins"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ===================== OVERLAYS ===================== -->
                    <Border Grid.Row="1" Classes="card" Padding="40"
                            IsVisible="{Binding SelectedSection, Converter={StaticResource StringEquals}, ConverterParameter=Overlays}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" MaxWidth="460">
                            <Path Width="44" Height="44" Stretch="Uniform" Opacity="0.6"
                                  Fill="{StaticResource FrostDimBrush}" Data="M4 4h16v5H4z M4 11h16v3H4z M4 16h16v3H4z"/>
                            <TextBlock Text="Overlays" Classes="h2" HorizontalAlignment="Center"/>
                            <TextBlock Classes="subtitle" HorizontalAlignment="Center" TextAlignment="Center"
                                       Text="Native WebView2 overlay windows — transparent, click-through, and cactbot-compatible — land in a later slice. For now, OverlayPlugin serves its overlays from the satellite."/>
                        </StackPanel>
                    </Border>

                    <!-- ===================== SETTINGS ===================== -->
                    <ScrollViewer Grid.Row="1"
                                  IsVisible="{Binding SelectedSection, Converter={StaticResource StringEquals}, ConverterParameter=Settings}">
                        <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Left">
                            <Border Classes="card" Padding="22,18">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="Appearance" Classes="h2"/>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Theme" Classes="body"/>
                                            <TextBlock Text="The cold-field palette drawn from the key art." Classes="meta" FontSize="11"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{StaticResource RimeBrush}" CornerRadius="6"
                                                Padding="11,6" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="11" Height="11" Fill="{StaticResource FrostBrush}"/>
                                                <Ellipse Width="11" Height="11" Fill="{StaticResource EmberBrush}"/>
                                                <TextBlock Text="Evercold" Foreground="{StaticResource GlintBrush}"
                                                           FontSize="12.5" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" Padding="22,18">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Startup" Classes="h2"/>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Launch the satellite with the host" Classes="body"/>
                                            <TextBlock Text="Starts the .NET 4.8 process automatically on open." Classes="meta" FontSize="11"/>
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent=""/>
                                    </Grid>
                                    <Border Height="1" Background="{StaticResource HairlineBrush}"/>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Embed plugin tabs in the host window" Classes="body"/>
                                            <TextBlock Text="Reparents each plugin's WinForms tabs into this shell." Classes="meta" FontSize="11"/>
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent=""/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" Padding="22,18">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="About" Classes="h2" Margin="0,0,0,6"/>
                                    <TextBlock Classes="meta" Text="FFXIV Combat Tracker · host shell"/>
                                    <TextBlock Classes="meta" Text="Two runtimes, two processes — net48 satellite + net10 host, bridged over a named pipe."/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
