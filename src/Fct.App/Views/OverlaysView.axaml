<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Fct.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="620"
             x:Class="Fct.App.Views.OverlaysView"
             x:DataType="vm:OverlaysViewModel">

    <Border Classes="card" Padding="40">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" MaxWidth="460">
            <Path Width="44" Height="44" Stretch="Uniform" Opacity="0.6"
                  Fill="{StaticResource FrostDimBrush}" Data="M4 4h16v5H4z M4 11h16v3H4z M4 16h16v3H4z"/>
            <TextBlock Text="Overlays" Classes="h2" HorizontalAlignment="Center"/>
            <TextBlock Classes="subtitle" HorizontalAlignment="Center" TextAlignment="Center"
                       Text="Native WebView2 overlay windows — transparent, click-through, and cactbot-compatible — land in a later slice. For now, OverlayPlugin serves its overlays from the satellite."/>
        </StackPanel>
    </Border>
</UserControl>
