<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Fct.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="620"
             x:Class="Fct.App.Views.PluginsView"
             x:DataType="vm:PluginsViewModel"
             d:DataContext="{x:Static vm:DesignData.Plugins}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Compact page chrome (the shared header is hidden on this page) -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Classes="rise1" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="PLUGINS" Classes="eyebrow"/>
                <TextBlock Text="Plugin Setup" Classes="h2" FontSize="21"/>
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="#0E1620" BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="1" CornerRadius="20" Padding="14,7">
                <StackPanel Orientation="Horizontal" Spacing="9">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding Shell.SatelliteState, Converter={StaticResource StatusToBrush}}"/>
                    <TextBlock Text="{Binding Shell.SatelliteState}" FontFamily="{StaticResource MonoFont}"
                               FontSize="12" Foreground="{StaticResource GlintBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Error banner -->
        <Border Grid.Row="1" IsVisible="{Binding Shell.HasError}" Margin="0,0,0,16"
                Background="#241317" BorderBrush="{StaticResource WarnBrush}"
                BorderThickness="1" CornerRadius="12" Padding="18,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="3">
                    <TextBlock Text="The host could not start the satellite"
                               Foreground="{StaticResource GlintBrush}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Shell.ErrorMessage}" Classes="meta" FontSize="11.5"
                               TextWrapping="Wrap" MaxWidth="700" HorizontalAlignment="Left"/>
                </StackPanel>
                <Button Grid.Column="1" Classes="ghost" Content="Retry" VerticalAlignment="Center"
                        AutomationProperties.AutomationId="plugins.retry"
                        Command="{Binding RetryCommand}"/>
            </Grid>
        </Border>

        <!-- Channel rail + bay -->
        <Grid Grid.Row="2" ColumnDefinitions="212,18,*">

            <!-- Drag to widen the channel rail (and shrink the embedded plugin config bay). -->
            <GridSplitter Grid.Column="1" Classes="pane" ResizeDirection="Columns"/>

            <!-- ===== Channel rail: quick switch between plugins ===== -->
            <Border Grid.Column="0" Classes="card rise2" Padding="0" MinWidth="180" MaxWidth="320">
                <DockPanel Margin="10">
                    <Grid DockPanel.Dock="Top" Margin="6,6,6,12">
                        <TextBlock Text="CHANNELS" Classes="eyebrow" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Shell.LoadedCount}" Classes="meta" FontSize="11"
                                   Foreground="{StaticResource FrostBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <Button DockPanel.Dock="Bottom" Classes="railmanage" Margin="0,10,0,0"
                            Classes.active="{Binding IsManage}" Command="{Binding ManageCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="11" Margin="13,0">
                            <Path Width="14" Height="14" Stretch="Uniform" StrokeThickness="1.6"
                                  Data="M8 1 V15 M1 8 H15"/>
                            <TextBlock Text="Manage plugins" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                        <ListBox Classes="rail" ItemsSource="{Binding Shell.Plugins}"
                                 SelectedItem="{Binding Shell.SelectedPlugin, Mode=TwoWay}"
                                 AutomationProperties.AutomationId="plugin.rail"
                                 AutomationProperties.Name="Plugin channels"
                                 Tapped="OnRailTapped">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:PluginViewModel">
                                    <Border Classes="railcard">
                                        <Grid ColumnDefinitions="Auto,Auto,*">
                                            <Rectangle Grid.Column="0" Classes="railbar" Width="3" Height="26"
                                                       Fill="{StaticResource FrostBrush}" RadiusX="2" RadiusY="2"
                                                       VerticalAlignment="Center" Margin="0,0,11,0"/>
                                            <Grid Grid.Column="1" Width="18" Height="18" VerticalAlignment="Center"
                                                  Margin="0,0,11,0">
                                                <Border Width="18" Height="18" CornerRadius="9"
                                                        Classes.pulse="{Binding IsLive}"
                                                        Background="{Binding Status, Converter={StaticResource StatusToBrush}, ConverterParameter=glow}"/>
                                                <Ellipse Width="10" Height="10" Classes.ping="{Binding IsLive}"
                                                         Stroke="{StaticResource EmberBrush}" StrokeThickness="1.4"
                                                         Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Ellipse Width="8" Height="8"
                                                         Fill="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                            </Grid>
                                            <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource GlintBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ===== Bay: Configure (the plugin's own tabs, full surface) ===== -->
            <Border Grid.Column="2" Classes="card" Padding="0" IsVisible="{Binding IsConfigure}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="0,0,0,1" Padding="20,15">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Grid Grid.Column="0" Width="26" Height="26" VerticalAlignment="Center" Margin="0,0,13,0">
                                <Border Width="26" Height="26" CornerRadius="13"
                                        Classes.pulse="{Binding Shell.SelectedPlugin.IsLive}"
                                        Background="{Binding Shell.SelectedPlugin.Status, Converter={StaticResource StatusToBrush}, ConverterParameter=glow}"/>
                                <Ellipse Width="14" Height="14" Classes.ping="{Binding Shell.SelectedPlugin.IsLive}"
                                         Stroke="{StaticResource EmberBrush}" StrokeThickness="1.5"
                                         Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Ellipse Width="11" Height="11"
                                         Fill="{Binding Shell.SelectedPlugin.Status, Converter={StaticResource StatusToBrush}}"/>
                            </Grid>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Shell.SelectedPlugin.Name}" Classes="h2"/>
                                <TextBlock Text="{Binding Shell.SelectedPlugin.Role}" Classes="meta" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Background="{StaticResource RimeBrush}" CornerRadius="6" Padding="10,5">
                                    <TextBlock Text="{Binding Shell.SelectedPlugin.Runtime}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="11"
                                               Foreground="{StaticResource FrostBrush}"/>
                                </Border>
                                <TextBlock Text="{Binding Shell.SelectedPlugin.StatusLabel}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="11.5"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Shell.SelectedPlugin.Status, Converter={StaticResource StatusToBrush}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Margin="16">
                        <!-- Native (legacy) plugin config tabs -->
                        <Grid IsVisible="{Binding Shell.SelectedPlugin.HasNativeConfig}">
                            <!-- Embedded foreign HWND lands here once the satellite is up -->
                            <Border Name="EmbedSlot" IsVisible="{Binding Shell.ConfigReady}"
                                    Background="#070A0E" BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1" CornerRadius="10" ClipToBounds="True"/>
                            <!-- Not-ready note -->
                            <Border IsVisible="{Binding Shell.ConfigReady, Converter={StaticResource InverseBool}}"
                                    Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1" CornerRadius="10">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                    <Path Width="34" Height="34" Stretch="Uniform" Opacity="0.5"
                                          Fill="{StaticResource HoarfrostBrush}" Data="M12 2 L20 9 L12 22 L4 9 Z"/>
                                    <TextBlock Text="Configuration loads when the host is online"
                                               Classes="meta" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Preview / native plugin (no legacy tabs) -->
                        <Border IsVisible="{Binding Shell.SelectedPlugin.HasNativeConfig, Converter={StaticResource InverseBool}}"
                                Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" CornerRadius="10">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" MaxWidth="420">
                                <Path Width="40" Height="40" Stretch="Uniform" Opacity="0.6"
                                      Fill="{StaticResource FrostDimBrush}" Data="M12 2 L20 9 L12 22 L4 9 Z"/>
                                <TextBlock Text="{Binding Shell.SelectedPlugin.ConfigPlaceholderTitle}" Classes="h2" HorizontalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Classes="subtitle"
                                           Text="{Binding Shell.SelectedPlugin.ConfigPlaceholderBody}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- ===== Bay: Manage (add / remove / enable / reorder) ===== -->
            <Border Grid.Column="2" Classes="card" Padding="0" IsVisible="{Binding IsManage}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="22,18,22,16" ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="3" VerticalAlignment="Center">
                            <TextBlock Text="Installed plugins" Classes="h2"/>
                            <TextBlock Text="{Binding Shell.LoadedSummary}" Classes="meta" FontSize="11"/>
                        </StackPanel>
                        <Button Grid.Column="1" Classes="ghost" VerticalAlignment="Center"
                                AutomationProperties.Name="Add plugin"
                                AutomationProperties.AutomationId="plugins.add"
                                Command="{Binding AddPluginCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Path Width="12" Height="12" Stretch="Uniform" Stroke="{StaticResource FrostBrush}"
                                      StrokeThickness="1.6" Data="M7 1 V13 M1 7 H13"/>
                                <TextBlock Text="Add plugin"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="0,1,0,0" Padding="22,12">
                        <TextBlock Classes="meta" FontSize="11" TextWrapping="Wrap"
                                   Text="The .NET 4.8 satellite loads plugins at startup. Enabling, reordering, and newly added plugins take effect on the next host launch."/>
                    </Border>

                    <ScrollViewer Padding="22,4,22,12">
                        <ItemsControl ItemsSource="{Binding Shell.Plugins}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PluginViewModel">
                                    <Border Classes="rackrow">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                                            <!-- reorder -->
                                            <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <Button Classes="iconbtn" AutomationProperties.Name="Move plugin up"
                                                        Command="{Binding ((vm:PluginsViewModel)DataContext).MoveUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Path Width="10" Height="6" Stretch="Uniform"
                                                          StrokeThickness="1.5" Data="M1 6 L6 1 L11 6"/>
                                                </Button>
                                                <Button Classes="iconbtn" AutomationProperties.Name="Move plugin down"
                                                        Command="{Binding ((vm:PluginsViewModel)DataContext).MoveDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Path Width="10" Height="6" Stretch="Uniform"
                                                          StrokeThickness="1.5" Data="M1 1 L6 6 L11 1"/>
                                                </Button>
                                            </StackPanel>
                                            <!-- status orb -->
                                            <Grid Grid.Column="1" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,13,0">
                                                <Border Width="20" Height="20" CornerRadius="10"
                                                        Background="{Binding Status, Converter={StaticResource StatusToBrush}, ConverterParameter=glow}"/>
                                                <Ellipse Width="9" Height="9"
                                                         Fill="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                            </Grid>
                                            <!-- identity -->
                                            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource GlintBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Classes="meta" FontSize="11" TextTrimming="CharacterEllipsis"
                                                           Text="{Binding Role}"/>
                                            </StackPanel>
                                            <!-- status + enable -->
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12"
                                                        VerticalAlignment="Center" Margin="12,0">
                                                <TextBlock Text="{Binding StatusLabel}" VerticalAlignment="Center"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                                <ToggleSwitch OnContent="" OffContent="" VerticalAlignment="Center"
                                                              IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                              IsEnabled="{Binding CanToggle}"/>
                                            </StackPanel>
                                            <!-- remove -->
                                            <Button Grid.Column="4" Classes="iconbtn danger" VerticalAlignment="Center"
                                                    AutomationProperties.Name="Remove plugin"
                                                    Command="{Binding ((vm:PluginsViewModel)DataContext).RemovePluginCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Path Width="11" Height="11" Stretch="Uniform"
                                                      StrokeThickness="1.5" Data="M2 2 L11 11 M11 2 L2 11"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
