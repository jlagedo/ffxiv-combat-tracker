<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Fct.App.ViewModels"
             xmlns:lang="using:Fct.App.Lang"
             xmlns:views="using:Fct.App.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="620"
             x:Class="Fct.App.Views.PluginsView"
             x:DataType="vm:PluginsViewModel"
             d:DataContext="{x:Static vm:DesignData.Plugins}">

    <UserControl.Resources>
        <!-- One roster row, shared by the legacy and modern lists. -->
        <DataTemplate x:Key="RailItem" x:DataType="vm:PluginViewModel">
            <Border Classes="railcard">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                    <Rectangle Grid.Column="0" Classes="railbar" Width="3" Height="26"
                               Fill="{StaticResource FrostBrush}" RadiusX="2" RadiusY="2"
                               VerticalAlignment="Center" Margin="0,0,11,0"/>
                    <Grid Grid.Column="1" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,11,0">
                        <Border Width="18" Height="18" CornerRadius="9" Classes.pulse="{Binding IsPulsing}"
                                Background="{Binding Status, Converter={StaticResource StatusToBrush}, ConverterParameter=glow}"/>
                        <Ellipse Width="10" Height="10" Classes.ping="{Binding IsPulsing}"
                                 Stroke="{StaticResource EmberBrush}" StrokeThickness="1.4"
                                 Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Ellipse Width="8" Height="8" Fill="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                    </Grid>
                    <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource GlintBrush}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding StatusLabel}" FontFamily="{StaticResource MonoFont}" FontSize="10"
                                   Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                    </StackPanel>
                    <Border Grid.Column="3" IsVisible="{Binding IsLegacy}" VerticalAlignment="Center"
                            Background="{StaticResource RimeBrush}" CornerRadius="5" Padding="7,3" Margin="8,0,0,0">
                        <TextBlock Text="{x:Static lang:Resources.Label_Legacy}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="9.5"
                                   Foreground="{StaticResource FrostBrush}"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Compact page chrome -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Classes="rise1" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="{x:Static lang:Resources.Eyebrow_Plugins}" Classes="eyebrow"/>
                <TextBlock Text="{x:Static lang:Resources.Nav_Plugins}" Classes="h2" FontSize="21"/>
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center" Classes="ghost"
                    AutomationProperties.AutomationId="plugins.add"
                    Command="{Binding Shell.AddPluginCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Path Width="12" Height="12" Stretch="Uniform" Stroke="{StaticResource FrostBrush}"
                          StrokeThickness="1.6" Data="M7 1 V13 M1 7 H13"/>
                    <TextBlock Text="{x:Static lang:Resources.Action_AddPlugin}"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Error banner -->
        <Border Grid.Row="1" IsVisible="{Binding Shell.HasError}" Margin="0,0,0,16"
                Background="#241317" BorderBrush="{StaticResource WarnBrush}"
                BorderThickness="1" CornerRadius="12" Padding="18,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="3">
                    <TextBlock Text="{x:Static lang:Resources.Plugins_EngineDownTitle}" Foreground="{StaticResource GlintBrush}"
                               FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Shell.ErrorMessage}" Classes="meta" FontSize="11.5"
                               TextWrapping="Wrap" MaxWidth="620" HorizontalAlignment="Left"/>
                </StackPanel>
                <Button Grid.Column="1" Classes="ghost" Content="{x:Static lang:Resources.Action_Restart}" VerticalAlignment="Center"
                        AutomationProperties.AutomationId="plugins.retry"
                        Command="{Binding Shell.RestartSatelliteCommand}"/>
            </Grid>
        </Border>

        <!-- Grouped roster + bay -->
        <Grid Grid.Row="2" ColumnDefinitions="248,18,*">

            <GridSplitter Grid.Column="1" Classes="pane" ResizeDirection="Columns"/>

            <!-- ===== Unified roster ===== -->
            <Border Grid.Column="0" Classes="card rise2" Padding="0" MinWidth="210" MaxWidth="360">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" Padding="10,12">
                    <StackPanel Spacing="6">
                        <ListBox Classes="rail" ItemsSource="{Binding Shell.Plugins}"
                                 ItemTemplate="{StaticResource RailItem}"
                                 SelectedItem="{Binding Shell.SelectedPlugin, Mode=TwoWay}"
                                 AutomationProperties.AutomationId="plugin.rail"
                                 AutomationProperties.Name="{x:Static lang:Resources.A11y_PluginsList}"/>
                        <TextBlock Text="{x:Static lang:Resources.Plugins_NoneLoaded}" Classes="meta" FontSize="11" Margin="8,2,0,4"
                                   IsVisible="{Binding !Shell.HasPlugins}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===== Bay ===== -->
            <Border Grid.Column="2" Classes="card" Padding="0">
                <Grid>
                    <!-- No selection -->
                    <StackPanel IsVisible="{Binding !Shell.HasSelection}" VerticalAlignment="Center"
                                HorizontalAlignment="Center" Spacing="10" MaxWidth="360">
                        <Path Width="40" Height="40" Stretch="Uniform" Opacity="0.5"
                              Fill="{StaticResource FrostDimBrush}" Data="M12 2 L20 9 L12 22 L4 9 Z"/>
                        <TextBlock Text="{x:Static lang:Resources.Plugins_SelectPluginTitle}" Classes="h2" HorizontalAlignment="Center"/>
                        <TextBlock Classes="subtitle" HorizontalAlignment="Center" TextAlignment="Center"
                                   Text="{x:Static lang:Resources.Plugins_SelectPluginBody}"/>
                    </StackPanel>

                    <DockPanel IsVisible="{Binding Shell.HasSelection}">
                        <!-- Bay header -->
                        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="0,0,0,1" Padding="20,15">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Grid Grid.Column="0" Width="26" Height="26" VerticalAlignment="Center" Margin="0,0,13,0">
                                    <Border Width="26" Height="26" CornerRadius="13"
                                            Classes.pulse="{Binding Shell.SelectedPlugin.IsPulsing}"
                                            Background="{Binding Shell.SelectedPlugin.Status, Converter={StaticResource StatusToBrush}, ConverterParameter=glow}"/>
                                    <Ellipse Width="14" Height="14" Classes.ping="{Binding Shell.SelectedPlugin.IsPulsing}"
                                             Stroke="{StaticResource EmberBrush}" StrokeThickness="1.5"
                                             Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse Width="11" Height="11"
                                             Fill="{Binding Shell.SelectedPlugin.Status, Converter={StaticResource StatusToBrush}}"/>
                                </Grid>
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Shell.SelectedPlugin.Name}" Classes="h2"/>
                                    <TextBlock Text="{Binding Shell.SelectedPlugin.Role}" Classes="meta" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <Border Background="{StaticResource RimeBrush}" CornerRadius="6" Padding="10,5"
                                            IsVisible="{Binding Shell.SelectedPlugin.IsLegacy}">
                                        <TextBlock Text="{x:Static lang:Resources.Label_Legacy}"
                                                   FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                   Foreground="{StaticResource FrostBrush}"/>
                                    </Border>
                                    <TextBlock Text="{Binding Shell.SelectedPlugin.StatusLabel}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="11.5"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Shell.SelectedPlugin.Status, Converter={StaticResource StatusToBrush}}"/>
                                    <Button Classes="ghost" Content="{x:Static lang:Resources.Action_Remove}" VerticalAlignment="Center"
                                            AutomationProperties.AutomationId="plugin.unload"
                                            Command="{Binding Shell.UnloadPluginCommand}"
                                            CommandParameter="{Binding Shell.SelectedPlugin}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Margin="16">
                            <!-- Legacy embedded config -->
                            <Grid IsVisible="{Binding Shell.SelectedPlugin.HasNativeConfig}">
                                <Border Name="EmbedSlot" IsVisible="{Binding Shell.ConfigReady}"
                                        Background="#070A0E" BorderBrush="{StaticResource HairlineBrush}"
                                        BorderThickness="1" CornerRadius="10" ClipToBounds="True"/>
                                <Border IsVisible="{Binding Shell.ConfigReady, Converter={StaticResource InverseBool}}"
                                        Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                                        BorderThickness="1" CornerRadius="10">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                        <Path Width="34" Height="34" Stretch="Uniform" Opacity="0.5"
                                              Fill="{StaticResource HoarfrostBrush}" Data="M12 2 L20 9 L12 22 L4 9 Z"/>
                                        <TextBlock Text="{x:Static lang:Resources.Plugins_ConfigLoadingBody}"
                                                   Classes="meta" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Native plugin details (fallback when the plugin contributed no settings page) -->
                            <Border IsVisible="{Binding Shell.SelectedPlugin.ShowNativeDetails}"
                                    Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="24,22">
                                <StackPanel Spacing="16" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Shell.SelectedPlugin.Description}" Classes="body" MaxWidth="520"
                                               HorizontalAlignment="Left"/>
                                    <Border Classes="rule" Width="52" HorizontalAlignment="Left"/>
                                    <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                                        <TextBlock Grid.Row="0" Text="{x:Static lang:Resources.Label_Identity}" Classes="eyebrow" FontSize="9.5"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Shell.SelectedPlugin.Name}"
                                                   Classes="body" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                                        <TextBlock Grid.Row="1" Text="{x:Static lang:Resources.Label_Version}" Classes="eyebrow" FontSize="9.5"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Shell.SelectedPlugin.Version}"
                                                   Classes="body" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                                        <TextBlock Grid.Row="2" Text="{x:Static lang:Resources.Label_Contract}" Classes="eyebrow" FontSize="9.5"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Shell.SelectedPlugin.ContractVersion}"
                                                   Classes="body" FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>
                                        <TextBlock Grid.Row="3" Text="{x:Static lang:Resources.Label_Author}" Classes="eyebrow" FontSize="9.5"
                                                   IsVisible="{Binding Shell.SelectedPlugin.HasAuthor}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Shell.SelectedPlugin.Author}"
                                                   Classes="body" FontFamily="{StaticResource MonoFont}" FontSize="12.5"
                                                   IsVisible="{Binding Shell.SelectedPlugin.HasAuthor}"/>
                                    </Grid>
                                    <TextBlock Classes="meta" FontSize="11" TextWrapping="Wrap" MaxWidth="520"
                                               HorizontalAlignment="Left"
                                               Text="{x:Static lang:Resources.Plugins_ModernConfigNote}"/>
                                </StackPanel>
                            </Border>

                            <!-- Plugin-contributed settings page (IUiContributor.RegisterUi, work item 9) -->
                            <Border IsVisible="{Binding Shell.SelectedPlugin.HasModernUi}"
                                    Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                                <views:PluginSurfaceView Surface="{Binding Shell.SelectedPlugin.SettingsSurface}"/>
                            </Border>

                            <!-- Legacy plugin installed by reference whose source files are gone -->
                            <Border IsVisible="{Binding Shell.SelectedPlugin.IsMissing}"
                                    Background="#0B1016" BorderBrush="{StaticResource WarnBrush}"
                                    BorderThickness="1" CornerRadius="10">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" MaxWidth="460">
                                    <Path Width="38" Height="38" Stretch="Uniform" Opacity="0.55"
                                          Fill="{StaticResource WarnBrush}" Data="M12 2 L20 9 L12 22 L4 9 Z"/>
                                    <TextBlock Text="{x:Static lang:Resources.Plugins_MissingTitle}" Classes="h2"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Classes="subtitle"
                                               Text="{x:Static lang:Resources.Plugins_MissingBody}"/>
                                    <Border Background="{StaticResource RimeBrush}" CornerRadius="6" Padding="10,6"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Shell.SelectedPlugin.SourceDir}"
                                                   FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                   Foreground="{StaticResource HoarfrostBrush}"
                                                   TextWrapping="Wrap" MaxWidth="420"/>
                                    </Border>
                                    <Button Classes="ghost" HorizontalAlignment="Center"
                                            Content="{x:Static lang:Resources.Action_Locate}"
                                            AutomationProperties.AutomationId="plugin.locate"
                                            Command="{Binding Shell.LocatePluginCommand}"
                                            CommandParameter="{Binding Shell.SelectedPlugin}"/>
                                </StackPanel>
                            </Border>

                            <!-- Still loading (legacy or modern, identical): a plain placeholder so the
                                 bay isn't a weird half-empty card while the plugin starts up -->
                            <Border IsVisible="{Binding Shell.SelectedPlugin.IsLoading}"
                                    Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1" CornerRadius="10">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" MaxWidth="440">
                                    <Border Width="38" Height="38" CornerRadius="9" Classes="pulse"
                                            Background="{Binding Shell.SelectedPlugin.Status, Converter={StaticResource StatusToBrush}, ConverterParameter=glow}"/>
                                    <TextBlock Text="{x:Static lang:Resources.Plugins_LoadingTitle}" Classes="h2"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Classes="subtitle"
                                               Text="{x:Static lang:Resources.Plugins_LoadingBody}"/>
                                </StackPanel>
                            </Border>

                            <!-- Legacy plugin with no embeddable window -->
                            <Border IsVisible="{Binding Shell.SelectedPlugin.ShowLegacyPlaceholder}"
                                    Background="#0B1016" BorderBrush="{StaticResource HairlineBrush}"
                                    BorderThickness="1" CornerRadius="10">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" MaxWidth="440">
                                    <Path Width="38" Height="38" Stretch="Uniform" Opacity="0.55"
                                          Fill="{StaticResource FrostDimBrush}" Data="M12 2 L20 9 L12 22 L4 9 Z"/>
                                    <TextBlock Text="{Binding Shell.SelectedPlugin.ConfigPlaceholderTitle}" Classes="h2"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Classes="subtitle"
                                               Text="{Binding Shell.SelectedPlugin.ConfigPlaceholderBody}"/>
                                    <Border Background="{StaticResource RimeBrush}" CornerRadius="6" Padding="10,6"
                                            HorizontalAlignment="Center" IsVisible="{Binding Shell.SelectedPlugin.HasStatusText}">
                                        <TextBlock Text="{Binding Shell.SelectedPlugin.SatelliteStatusText}"
                                                   FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                   Foreground="{StaticResource HoarfrostBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
