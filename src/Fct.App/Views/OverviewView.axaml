<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Fct.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="620"
             x:Class="Fct.App.Views.OverviewView"
             x:DataType="vm:OverviewViewModel"
             d:DataContext="{x:Static vm:DesignData.Overview}">

    <ScrollViewer>
        <StackPanel Spacing="16">

            <!-- Connection + plugins at a glance -->
            <Grid ColumnDefinitions="*,16,*">

                <!-- Connection -->
                <Border Grid.Column="0" Classes="card rise1" Padding="22,18">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Connection" Classes="h2"/>
                        <Border Classes="rule" Width="52" HorizontalAlignment="Left"/>

                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="13">
                            <Ellipse Grid.Row="0" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,11,0"
                                     Fill="{Binding Shell.HostStateLabel, Converter={StaticResource StatusToBrush}}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Host" Classes="body" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="online · .NET 10" Classes="meta" VerticalAlignment="Center"/>

                            <Ellipse Grid.Row="1" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,11,0"
                                     Fill="{Binding Shell.SatelliteState, Converter={StaticResource StatusToBrush}}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Satellite" Classes="body" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Shell.SatelliteState}" Classes="meta"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding Shell.SatelliteState, Converter={StaticResource StatusToBrush}}"/>

                            <Ellipse Grid.Row="2" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,11,0"
                                     Fill="{Binding Shell.GameStateLabel, Converter={StaticResource StatusToBrush}}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Game data" Classes="body" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Shell.GameStateLabel}" Classes="meta"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding Shell.GameStateLabel, Converter={StaticResource StatusToBrush}}"/>
                        </Grid>

                        <Button Classes="ghost small" Content="Restart satellite" HorizontalAlignment="Left"
                                Command="{Binding Shell.RestartSatelliteCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Plugins -->
                <Border Grid.Column="2" Classes="card rise2" Padding="22,18">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Plugins" Classes="h2"/>
                        <Border Classes="rule" Width="52" HorizontalAlignment="Left"/>

                        <Grid ColumnDefinitions="*,*,*">
                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Text="{Binding Shell.LegacyLoadedCount}" Classes="h1" FontSize="30"/>
                                <TextBlock Text="legacy" Classes="meta" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3">
                                <TextBlock Text="{Binding Shell.ModernLoadedCount}" Classes="h1" FontSize="30"/>
                                <TextBlock Text="modern" Classes="meta" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="3">
                                <TextBlock Text="{Binding Shell.FaultCount}" Classes="h1" FontSize="30"
                                           Foreground="{StaticResource WarnBrush}"/>
                                <TextBlock Text="faults" Classes="meta" FontSize="11"/>
                            </StackPanel>
                        </Grid>

                        <Button Classes="ghost small" Content="Manage plugins" HorizontalAlignment="Left"
                                Command="{Binding Shell.SelectPageCommand}" CommandParameter="Plugins"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent activity -->
            <Border Classes="card rise3" Padding="0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="22,18,18,12" ColumnDefinitions="*,Auto">
                        <TextBlock Text="Recent activity" Classes="h2" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Classes="ghost small" Content="Open notifications"
                                VerticalAlignment="Center"
                                Command="{Binding Shell.Notifications.ToggleCenterCommand}"/>
                    </Grid>

                    <StackPanel IsVisible="{Binding !Shell.Notifications.HasHistory}" Margin="22,6,22,26" Spacing="6">
                        <TextBlock Text="Nothing has happened yet." Classes="meta"/>
                        <TextBlock Text="Plugin messages, errors, and load events will appear here." Classes="meta" FontSize="11"/>
                    </StackPanel>

                    <ItemsControl IsVisible="{Binding Shell.Notifications.HasHistory}"
                                  ItemsSource="{Binding Shell.Notifications.History}" Margin="12,0,12,10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:NotificationViewModel">
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="10,7">
                                    <TextBlock Grid.Column="0" Text="{Binding TimeLabel}" Classes="meta" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Ellipse Grid.Column="1" Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,11,0"
                                             Fill="{Binding Severity, Converter={StaticResource SeverityToBrush}}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Title}" Classes="body" FontSize="12.5"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Source}" Classes="eyebrow" FontSize="9.5"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- Quick actions -->
            <StackPanel Orientation="Horizontal" Spacing="12" Classes="rise4">
                <Button Classes="ghost" Content="Add plugin" Command="{Binding Shell.AddPluginCommand}"/>
                <Button Classes="ghost" Content="Configure plugins"
                        Command="{Binding Shell.SelectPageCommand}" CommandParameter="Plugins"/>
                <Button Classes="ghost" Content="View encounters"
                        Command="{Binding Shell.SelectPageCommand}" CommandParameter="Encounters"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
