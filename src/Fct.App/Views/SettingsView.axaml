<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Fct.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="620"
             x:Class="Fct.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Left">
            <Border Classes="card rise1" Padding="22,18">
                <StackPanel Spacing="14">
                    <TextBlock Text="Appearance" Classes="h2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Theme" Classes="body"/>
                            <TextBlock Text="The cold-field palette drawn from the key art." Classes="meta" FontSize="11"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="{StaticResource RimeBrush}" CornerRadius="6"
                                Padding="11,6" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="11" Height="11" Fill="{StaticResource FrostBrush}"/>
                                <Ellipse Width="11" Height="11" Fill="{StaticResource EmberBrush}"/>
                                <TextBlock Text="Evercold" Foreground="{StaticResource GlintBrush}"
                                           FontSize="12.5" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card rise2" Padding="22,18">
                <StackPanel Spacing="16">
                    <TextBlock Text="Startup" Classes="h2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Launch the satellite with the host" Classes="body"/>
                            <TextBlock Text="Starts the .NET 4.8 process automatically on open." Classes="meta" FontSize="11"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent=""/>
                    </Grid>
                    <Border Height="1" Background="{StaticResource HairlineBrush}"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Embed plugin tabs in the host window" Classes="body"/>
                            <TextBlock Text="Reparents each plugin's WinForms tabs into this shell." Classes="meta" FontSize="11"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="True" OnContent="" OffContent=""/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card rise3" Padding="22,18">
                <StackPanel Spacing="6">
                    <TextBlock Text="About" Classes="h2" Margin="0,0,0,6"/>
                    <TextBlock Classes="meta" Text="FFXIV Combat Tracker · host shell"/>
                    <TextBlock Classes="meta" Text="Two runtimes, two processes — net48 satellite + net10 host, bridged over a named pipe."/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
