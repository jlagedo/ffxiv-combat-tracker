<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Fct.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="620"
             x:Class="Fct.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             d:DataContext="{x:Static vm:DesignData.Settings}">

    <ScrollViewer>
        <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Left">

            <Border Classes="card rise1" Padding="22,18">
                <StackPanel Spacing="16">
                    <TextBlock Text="Startup" Classes="h2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Start the classic engine automatically" Classes="body"/>
                            <TextBlock Text="Starts the classic plugin engine when the app opens. Turn off to start it yourself from the Plugins page."
                                       Classes="meta" FontSize="11" TextWrapping="Wrap" MaxWidth="520" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding LaunchSatelliteOnStartup, Mode=TwoWay}"
                                      OnContent="" OffContent="" VerticalAlignment="Center"
                                      AutomationProperties.Name="Start the classic engine automatically"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card rise2" Padding="22,18">
                <StackPanel Spacing="14">
                    <TextBlock Text="Appearance" Classes="h2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Theme" Classes="body"/>
                            <TextBlock Text="The cold-field palette drawn from the game's crystal motif." Classes="meta" FontSize="11"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="{StaticResource RimeBrush}" CornerRadius="6"
                                Padding="11,6" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="11" Height="11" Fill="{StaticResource FrostBrush}"/>
                                <Ellipse Width="11" Height="11" Fill="{StaticResource EmberBrush}"/>
                                <TextBlock Text="Evercold" Foreground="{StaticResource GlintBrush}"
                                           FontSize="12.5" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card rise3" Padding="22,18">
                <StackPanel Spacing="14">
                    <TextBlock Text="Diagnostics" Classes="h2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Logs" Classes="body"/>
                            <TextBlock Text="{Binding LogsDirectory}" Classes="meta" FontSize="11"
                                       TextTrimming="MiddleEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="1" Classes="ghost small" Content="Open logs folder"
                                VerticalAlignment="Center" Click="OnOpenLogs"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card rise4" Padding="22,18">
                <StackPanel Spacing="6">
                    <TextBlock Text="About" Classes="h2" Margin="0,0,0,6"/>
                    <TextBlock Classes="meta" Text="FFXIV Combat Tracker"/>
                    <TextBlock Classes="meta"
                               Text="Runs your existing ACT plugins alongside modern ones, with an opt-in path from classic to modern."/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
