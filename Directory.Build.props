<Project>

  <!--
    Repo-wide build defaults, imported early into every project under the repo root
    (src/, tests/, samples/). Any project may override a property locally: the net48 facade and
    legacy-host projects set <Nullable>disable</Nullable> themselves. build/ and tools/ carry their
    own (empty) Directory.Build.props so they opt out of these defaults — they are dev tooling, not
    shipping code, and stay isolated from the app's build graph.
  -->

  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <Deterministic>true</Deterministic>
  </PropertyGroup>

  <!-- Strict: compiler + analyzer warnings fail the build; code-style rules are enforced at build
       time (their severities are set in .editorconfig). -->
  <PropertyGroup>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <AnalysisLevel>latest</AnalysisLevel>
  </PropertyGroup>

  <!-- Shared assembly/package metadata. -->
  <PropertyGroup>
    <Product>FFXIV Combat Tracker</Product>
    <Authors>João Amaro Lagedo</Authors>
    <Copyright>Copyright © 2026</Copyright>
  </PropertyGroup>

  <!-- Shared version (SemVer 2.0). VersionSuffix marks pre-releases and is overridable per-build
       (e.g. /p:VersionSuffix=alpha.2). Empty suffix ships the stable 1.0.0. The SDK derives Version
       (1.0.0-alpha.1, the NuGet package version), AssemblyVersion/FileVersion (1.0.0.0 — suffix
       stripped), and InformationalVersion (1.0.0-alpha.1+<git-sha>) from these. -->
  <PropertyGroup>
    <VersionPrefix>1.0.0</VersionPrefix>
    <VersionSuffix>alpha.1</VersionSuffix>
  </PropertyGroup>

  <!-- Machine-local overrides (git-ignored, never committed). A developer whose real ACT install
       lives outside the default %APPDATA% location drops a Directory.Build.local.props here to set
       paths to the real third-party build inputs (e.g. ActExePath -> Advanced Combat Tracker.exe,
       consumed by the P7 net48 fixtures). No machine path is ever hardcoded in a committed file. -->
  <Import Project="$(MSBuildThisFileDirectory)Directory.Build.local.props"
          Condition="Exists('$(MSBuildThisFileDirectory)Directory.Build.local.props')" />

</Project>
