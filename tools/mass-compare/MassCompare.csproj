<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Dev tool (not in the solution). Joins the two ExportVariables payloads produced over a folder of
    captured plugin swing streams: the real-ACT baseline (name.oracle.exports.tsv, from
    tools/act-oracle) and our Fct.Compat.Act engine's output (name.engine.exports.tsv, from the
    satellite's mass-engine-exports mode), and reports how often our engine matches real ACT exactly.
    See tools/mass-compare/README.md and run.ps1.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>MassCompare</AssemblyName>
    <RootNamespace>Fct.MassCompare</RootNamespace>
  </PropertyGroup>

</Project>
