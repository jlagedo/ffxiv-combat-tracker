<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Dev tool (not in the solution). Runs the clean-room native parser over a whole folder of
    decoded Network_*.log files and diffs the result, file by file, against ACT's authoritative
    parse captured by the satellite's mass-oracle mode. Emits per-file ours TSVs, a report,
    and an aggregate summary. See tools/mass-compare/README.md.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>MassCompare</AssemblyName>
    <RootNamespace>Fct.MassCompare</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Fct.Parser.Native\Fct.Parser.Native.csproj" />
  </ItemGroup>

</Project>
