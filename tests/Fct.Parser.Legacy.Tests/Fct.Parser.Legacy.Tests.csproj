<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Tier 1 dispatcher tests for Fct.Parser.Legacy. net48 to match the wrapper TFM. Pure and
    deterministic: no game, no real plugin, no satellite. References the SDK Common.dll
    (copy-local here — in the test process our lib copy IS the single loaded identity) so the
    tests construct the real delegate types the dispatcher fans out.
  -->
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>disable</Nullable>
    <PlatformTarget>x64</PlatformTarget>
    <Prefer32Bit>false</Prefer32Bit>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Fct.Parser.Legacy\Fct.Parser.Legacy.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="FFXIV_ACT_Plugin.Common">
      <HintPath>..\..\lib\FFXIV_ACT_Plugin.Common.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
