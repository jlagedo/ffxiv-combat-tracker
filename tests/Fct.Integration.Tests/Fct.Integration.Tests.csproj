<Project Sdk="Microsoft.NET.Sdk">

  <!--
    End-to-end test of the net48 satellite as a black box: launch the staged
    Fct.LegacyHost.exe, complete the bridge handshake, and inspect its verification log.
    Skips when the satellite isn't staged or the real FFXIV plugin isn't installed, so it's
    safe on a clean checkout but exercises the real binaries where present.
    Fct.Bridge.Contracts is referenced to reuse the exact handshake parsing the host uses.
  -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Xunit.SkippableFact" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Fct.Bridge.Contracts\Fct.Bridge.Contracts.csproj" />
    <!-- The wire-path e2e (ReplayBridgeRouteTests) decodes the bridged GameEventFrames and folds them
         through the real host engine, asserting parity with the satellite's own captured totals. -->
    <ProjectReference Include="..\..\src\Fct.Engine\Fct.Engine.csproj" />
    <ProjectReference Include="..\..\src\Fct.Abstractions.Testing\Fct.Abstractions.Testing.csproj" />
    <!-- The P3 multi-satellite gate drives the internal SatelliteSupervisor (InternalsVisibleTo). -->
    <ProjectReference Include="..\..\src\Fct.Host\Fct.Host.csproj" />
  </ItemGroup>

</Project>
