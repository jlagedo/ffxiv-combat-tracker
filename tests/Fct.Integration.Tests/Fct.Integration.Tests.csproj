<Project Sdk="Microsoft.NET.Sdk">

  <!--
    End-to-end test of the net48 satellite as a black box: launch the staged
    Fct.LegacyHost.exe, complete the bridge handshake, and inspect its verification log.
    Skips when the satellite isn't staged or the real FFXIV plugin isn't installed, so it's
    safe on a clean checkout but exercises the real binaries where present.
    SatelliteProtocol.cs is linked to reuse the exact handshake parsing the host uses.
  -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageReference Include="Xunit.SkippableFact" Version="1.4.13" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\..\src\Fct.App\SatelliteProtocol.cs" Link="SatelliteProtocol.cs" />
  </ItemGroup>

</Project>
